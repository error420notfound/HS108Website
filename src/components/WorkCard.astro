---
interface Props {
  slug: string;
  title: string;
  client: string;
  year: number;
  categories: string[];
  coverImage: string;
  coverAlt: string;
  color: string;
  outcome: { label: string; value: string };
  summary: string;
  large?: boolean;
}

const {
  slug, title, client, year, categories,
  coverImage, coverAlt, color, outcome, summary,
  large = false,
} = Astro.props;
---

<a href={`/work/${slug}`} class:list={['work-card', { 'work-card--large': large }]}>
  <div class="work-card-img aspect-16-9" style={`background-color: ${color}18`}>
    <img src={coverImage} alt={coverAlt} class="img-raw" loading="lazy" />
  </div>

  <div class="work-card-body">
    <div class="work-card-meta">
      <span class="t-label">{client}</span>
      <span class="t-label muted">{year}</span>
    </div>
    <h3 class:list={['work-card-title', large ? 't-h2' : 't-h3']}>{title}</h3>
    <p class="t-body work-card-summary">{summary}</p>
    <div class="work-card-footer">
      <div class="work-card-cats">
        {categories.slice(0, 3).map(c => <span class="tag">{c}</span>)}
      </div>
      <div class="work-card-outcome">
        <span class="t-label muted">{outcome.label}</span>
        <span class="work-card-value">{outcome.value}</span>
      </div>
    </div>
  </div>
</a>

<style>
  .work-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    transition: border-color var(--dur-fast, 150ms), background var(--dur-fast, 150ms);
    text-decoration: none;
  }

  .work-card:hover {
    border-color: var(--color-border-mid);
    background: var(--color-bg-subtle);
  }

  .work-card-img {
    overflow: hidden;
  }

  .work-card-body {
    padding: var(--sp-5, 32px);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .work-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .work-card-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--color-text-primary);
  }

  .work-card-summary {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .work-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .work-card-cats {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .work-card-cats .tag {
    font-size: 11px;
    color: var(--color-text-faint);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 3px 8px;
    border-radius: 20px;
  }

  .work-card-outcome {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  .work-card-outcome .muted {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-faint);
    opacity: 1;
  }

  .work-card-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-text-primary);
  }
</style>
