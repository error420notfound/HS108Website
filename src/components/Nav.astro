---
const navLinks = [
  { label: 'Work',     href: '/work' },
  { label: 'Services', href: '/services' },
  { label: 'Process',  href: '/process' },
  { label: 'About',    href: '/about' },
  { label: 'Programs', href: '/programs' },
];

const programLinks = [
  { label: 'Creative Department', href: '/programs/creative-department' },
  { label: 'Design Lab',          href: '/programs/design-lab' },
  { label: 'off_menu',            href: '/programs/off-menu' },
  { label: 'Atelier Discourse',   href: '/programs/atelier-discourse' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-wrap">
  <nav class="nav container">
    <a href="/" class="nav-logo" aria-label="HS108 Home">
      <span class="nav-logo-text">HS108</span>
      <span class="nav-logo-dot"></span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="/contact" class="btn btn--primary nav-cta">Get In Touch</a>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      id="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>

  <!-- Mobile dropdown menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <ul role="list">
      {navLinks.filter(l => l.label !== 'Programs').map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-mobile-link', { active: currentPath.startsWith(link.href) }]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <!-- Programs sub-group -->
      <li class="nav-mobile-group-label">
        <span class="t-label" style="opacity:0.4">Programs</span>
      </li>
      {programLinks.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-mobile-link nav-mobile-link--sub', { active: currentPath === link.href }]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-mobile-footer">
      <a href="/contact" class="btn btn--primary nav-mobile-cta">
        Get In Touch →
      </a>
    </div>
  </div>
</header>

<style>
  /* ── Wrapper ── */
  .nav-wrap {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: var(--border-width) solid var(--border);
  }

  /* ── Bar ── */
  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
  }

  /* ── Logo ── */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-right: auto;
    text-decoration: none;
  }

  .nav-logo-text {
    font-family: var(--font-mono);   /* Geist Mono — works at any weight */
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--black-native);
  }

  .nav-logo-dot {
    width: 8px;
    height: 8px;
    background: var(--orange-500);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Desktop nav links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--size-label);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 8px 14px;
    display: block;
    transition: background var(--transition), color var(--transition);
    color: var(--black-native);
  }

  .nav-link:hover,
  .nav-link.active {
    background: var(--orange-500);
    color: var(--black-native);
  }

  /* ── Desktop CTA ── */
  .nav-cta {
    padding: 10px 18px;
    font-size: 10px;
    flex-shrink: 0;
  }

  /* ══════════════════════════════════════
     HAMBURGER BUTTON
  ══════════════════════════════════════ */
  .nav-hamburger {
    display: none;           /* shown only at mobile breakpoint */
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    cursor: pointer;
    background: none;
    border: var(--border-width) solid var(--border);
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 100%;             /* fills the 40px button width minus padding */
    height: 2px;
    background: var(--black-native);
    transition: transform 250ms ease, opacity 250ms ease;
    transform-origin: center;
  }

  /* Animated X when open */
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ══════════════════════════════════════
     MOBILE DROPDOWN
  ══════════════════════════════════════ */
  .nav-mobile {
    display: none;
    background: var(--bg);
    border-top: var(--border-width) solid var(--border);
    /* Dropdown from nav bar — no full-screen overlay */
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
  }

  .nav-mobile.open {
    display: block;
  }

  .nav-mobile ul {
    display: flex;
    flex-direction: column;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--black-native);
    padding: 1rem var(--gutter);
    border-bottom: 1px solid var(--orange-100);
    transition: background var(--transition), padding-left var(--transition);
  }

  .nav-mobile-link::after {
    content: '→';
    font-family: var(--font-mono);
    font-size: 11px;
    opacity: 0.35;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link.active {
    background: var(--orange-500);
    color: var(--black-native);
    padding-left: calc(var(--gutter) + 0.5rem);
  }

  .nav-mobile-link.active::after {
    opacity: 1;
  }

  .nav-mobile-group-label {
    padding: 0.75rem var(--gutter) 0.35rem;
    background: var(--surface-elevated);
    border-bottom: 1px solid var(--orange-100);
  }

  .nav-mobile-link--sub {
    padding-left: calc(var(--gutter) + 1rem);
    font-size: 11px;
    background: var(--surface-elevated);
  }

  .nav-mobile-link--sub:hover,
  .nav-mobile-link--sub.active {
    padding-left: calc(var(--gutter) + 1.5rem);
    background: var(--orange-200);
  }

  .nav-mobile-footer {
    padding: 1.25rem var(--gutter);
    border-top: var(--border-width) solid var(--border);
    background: var(--surface-elevated);
  }

  .nav-mobile-cta {
    width: 100%;
    justify-content: center;
  }

  /* ══════════════════════════════════════
     BREAKPOINT
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger')!;
  const mobileMenu = document.getElementById('nav-mobile')!;

  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close on link click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const header = document.querySelector('.nav-wrap');
    if (header && !header.contains(e.target as Node)) {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      mobileMenu.setAttribute('aria-hidden', 'true');
    }
  });
</script>
