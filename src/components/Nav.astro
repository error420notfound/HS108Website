---
const serviceLinks = [
  { label: 'WebCanvas',    sub: 'Digital Design',     href: '/services/webcanvas' },
  { label: 'CX&Identity',  sub: 'Branding & Identity', href: '/services/cx-identity' },
  { label: 'CMF_Nexus',    sub: 'Product Design',      href: '/services/cmf-nexus' },
  { label: 'Lumina.raw',   sub: 'Photo & Video',       href: '/services/lumina-raw' },
];

const aboutLinks = [
  { label: 'Studio',    sub: 'Who we are',       href: '/about' },
  { label: 'Why HS108', sub: 'Why choose us',    href: '/why-us' },
  { label: 'Process',   sub: 'How we work',      href: '/process' },
];

const programLinks = [
  { label: 'Creative Department', sub: 'Retainer',  href: '/programs/creative-department' },
  { label: 'Design Lab',          sub: 'Research',   href: '/programs/design-lab' },
  { label: 'off_menu',            sub: 'Bespoke',    href: '/programs/off-menu' },
  { label: 'Field Notes',         sub: 'Community',  href: '/programs/field-notes' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-wrap">
  <nav class="nav container">
    <a href="/" class="nav-logo" aria-label="HS108 Home">
      <span class="nav-logo-text">HS108</span>
      <span class="nav-logo-dot"></span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" role="list">
      <li>
        <a href="/work" class:list={['nav-link', { active: currentPath.startsWith('/work') }]}>Work</a>
      </li>

      <!-- Services dropdown -->
      <li class="nav-item--dropdown">
        <a href="/services" class:list={['nav-link nav-link--dropdown', { active: currentPath.startsWith('/services') }]}>
          Services <span class="nav-chevron">▾</span>
        </a>
        <div class="nav-dropdown">
          {serviceLinks.map(link => (
            <a href={link.href} class:list={['nav-dropdown-item', { active: currentPath === link.href }]}>
              <span class="nav-dropdown-label">{link.label}</span>
              <span class="nav-dropdown-sub">{link.sub}</span>
            </a>
          ))}
        </div>
      </li>

      <!-- About dropdown -->
      <li class="nav-item--dropdown">
        <a href="/about" class:list={['nav-link nav-link--dropdown', { active: currentPath.startsWith('/about') || currentPath.startsWith('/why-us') || currentPath.startsWith('/process') }]}>
          About <span class="nav-chevron">▾</span>
        </a>
        <div class="nav-dropdown">
          {aboutLinks.map(link => (
            <a href={link.href} class:list={['nav-dropdown-item', { active: currentPath === link.href }]}>
              <span class="nav-dropdown-label">{link.label}</span>
              <span class="nav-dropdown-sub">{link.sub}</span>
            </a>
          ))}
        </div>
      </li>

      <!-- Programs dropdown -->
      <li class="nav-item--dropdown">
        <a href="/programs" class:list={['nav-link nav-link--dropdown', { active: currentPath.startsWith('/programs') }]}>
          Programs <span class="nav-chevron">▾</span>
        </a>
        <div class="nav-dropdown">
          {programLinks.map(link => (
            <a href={link.href} class:list={['nav-dropdown-item', { active: currentPath === link.href }]}>
              <span class="nav-dropdown-label">{link.label}</span>
              <span class="nav-dropdown-sub">{link.sub}</span>
            </a>
          ))}
        </div>
      </li>
    </ul>

    <a href="/contact" class="btn btn--primary nav-cta">Get In Touch</a>

    <!-- Mobile hamburger -->
    <button
      class="nav-hamburger"
      id="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>

  <!-- Mobile dropdown menu -->
  <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
    <ul role="list">
      <li>
        <a href="/work" class:list={['nav-mobile-link', { active: currentPath.startsWith('/work') }]}>Work</a>
      </li>

      <!-- Services accordion -->
      <li class="nav-mobile-accordion">
        <button class="nav-mobile-link nav-mobile-accordion-btn" aria-expanded="false">
          Services <span class="nav-acc-chevron">▾</span>
        </button>
        <ul class="nav-mobile-submenu" role="list">
          <li class="nav-mobile-group-label">
            <span class="t-label" style="opacity:0.4">Services</span>
          </li>
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class:list={['nav-mobile-link nav-mobile-link--sub', { active: currentPath === link.href }]}>
                <span>{link.label}</span>
                <span class="nav-sub-tag">{link.sub}</span>
              </a>
            </li>
          ))}
        </ul>
      </li>

      <!-- About accordion -->
      <li class="nav-mobile-accordion">
        <button class="nav-mobile-link nav-mobile-accordion-btn" aria-expanded="false">
          About <span class="nav-acc-chevron">▾</span>
        </button>
        <ul class="nav-mobile-submenu" role="list">
          <li class="nav-mobile-group-label">
            <span class="t-label" style="opacity:0.4">About</span>
          </li>
          {aboutLinks.map(link => (
            <li>
              <a href={link.href} class:list={['nav-mobile-link nav-mobile-link--sub', { active: currentPath === link.href }]}>
                <span>{link.label}</span>
                <span class="nav-sub-tag">{link.sub}</span>
              </a>
            </li>
          ))}
        </ul>
      </li>

      <!-- Programs accordion -->
      <li class="nav-mobile-accordion">
        <button class="nav-mobile-link nav-mobile-accordion-btn" aria-expanded="false">
          Programs <span class="nav-acc-chevron">▾</span>
        </button>
        <ul class="nav-mobile-submenu" role="list">
          <li class="nav-mobile-group-label">
            <span class="t-label" style="opacity:0.4">Programs</span>
          </li>
          {programLinks.map(link => (
            <li>
              <a href={link.href} class:list={['nav-mobile-link nav-mobile-link--sub', { active: currentPath === link.href }]}>
                <span>{link.label}</span>
                <span class="nav-sub-tag">{link.sub}</span>
              </a>
            </li>
          ))}
        </ul>
      </li>
    </ul>

    <div class="nav-mobile-footer">
      <a href="/contact" class="btn btn--primary nav-mobile-cta">Get In Touch →</a>
    </div>
  </div>
</header>

<style>
  /* ── Wrapper ── */
  .nav-wrap {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 1px solid var(--color-border);
  }

  /* ── Bar ── */
  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
    padding: 0 60px;
  }

  /* ── Logo ── */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-right: auto;
    text-decoration: none;
  }

  .nav-logo-text {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-text-primary);
  }

  .nav-logo-dot {
    width: 8px;
    height: 8px;
    background: var(--orange-500);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Desktop nav links ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.02em;
    padding: 6px 12px;
    display: flex;
    align-items: center;
    gap: 4px;
    border-radius: 4px;
    transition: color var(--dur-fast), background var(--dur-fast);
    color: var(--color-text-muted);
    white-space: nowrap;
    height: 64px;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text-primary);
    background: rgba(26, 25, 23, 0.05);
  }

  .nav-chevron {
    font-size: 8px;
    opacity: 0.5;
    transition: transform 200ms ease;
  }

  /* ── Dropdown items ── */
  .nav-item--dropdown {
    position: relative;
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-top: none;
    min-width: 220px;
    z-index: 200;
    border-radius: 0 0 4px 4px;
  }

  .nav-item--dropdown:hover .nav-dropdown,
  .nav-item--dropdown:focus-within .nav-dropdown {
    display: block;
  }

  .nav-item--dropdown:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 10px 16px;
    border-bottom: 1px solid var(--color-border);
    transition: background var(--dur-fast);
  }

  .nav-dropdown-item:last-child {
    border-bottom: none;
  }

  .nav-dropdown-item:hover {
    background: var(--color-bg-subtle);
  }

  .nav-dropdown-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
  }

  .nav-dropdown-sub {
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-text-faint);
  }

  /* ── Desktop CTA ── */
  .nav-cta {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-bg-surface);
    background: var(--color-text-primary);
    padding: 8px 18px;
    border-radius: 2px;
    transition: opacity var(--dur-fast);
    flex-shrink: 0;
    text-decoration: none;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  /* ══════════════════════════════════════
     HAMBURGER BUTTON
  ══════════════════════════════════════ */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    cursor: pointer;
    background: none;
    border: var(--border-width) solid var(--border);
    flex-shrink: 0;
  }

  .bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--black-native);
    transition: transform 250ms ease, opacity 250ms ease;
    transform-origin: center;
  }

  .nav-hamburger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ══════════════════════════════════════
     MOBILE DROPDOWN
  ══════════════════════════════════════ */
  .nav-mobile {
    display: none;
    background: var(--bg);
    border-top: var(--border-width) solid var(--border);
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    max-height: calc(100dvh - 64px);
    overflow-y: auto;
  }

  .nav-mobile.open {
    display: block;
  }

  .nav-mobile > ul {
    display: flex;
    flex-direction: column;
  }

  .nav-mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--black-native);
    padding: 1rem var(--gutter);
    border-bottom: 1px solid var(--orange-100);
    transition: background var(--transition), padding-left var(--transition);
    width: 100%;
    background: none;
    cursor: pointer;
    text-align: left;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link.active {
    background: var(--orange-500);
    color: var(--black-native);
    padding-left: calc(var(--gutter) + 0.5rem);
  }

  .nav-mobile-group-label {
    padding: 0.75rem var(--gutter) 0.35rem;
    background: var(--surface-elevated);
    border-bottom: 1px solid var(--orange-100);
  }

  .nav-mobile-link--sub {
    padding-left: calc(var(--gutter) + 1rem);
    font-size: 11px;
    background: var(--surface-elevated);
    justify-content: flex-start;
    gap: 1rem;
  }

  .nav-mobile-link--sub:hover,
  .nav-mobile-link--sub.active {
    padding-left: calc(var(--gutter) + 1.5rem);
    background: var(--orange-200);
  }

  /* accordion submenu hidden by default */
  .nav-mobile-submenu {
    display: none;
    flex-direction: column;
  }

  .nav-mobile-submenu.open {
    display: flex;
  }

  .nav-acc-chevron {
    font-size: 8px;
    opacity: 0.5;
    transition: transform 200ms ease;
    flex-shrink: 0;
  }

  .nav-mobile-accordion-btn[aria-expanded="true"] .nav-acc-chevron {
    transform: rotate(180deg);
  }

  .nav-sub-tag {
    font-size: 9px;
    opacity: 0.4;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-left: auto;
  }

  .nav-mobile-footer {
    padding: 1.25rem var(--gutter);
    border-top: var(--border-width) solid var(--border);
    background: var(--surface-elevated);
  }

  .nav-mobile-cta {
    width: 100%;
    justify-content: center;
  }

  /* ══════════════════════════════════════
     BREAKPOINT
  ══════════════════════════════════════ */
  @media (max-width: 900px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>

<script>
  // ── Main mobile menu ──
  const hamburger = document.getElementById('nav-hamburger')!;
  const mobileMenu = document.getElementById('nav-mobile')!;

  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    hamburger.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close on link (non-accordion) click
  mobileMenu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    const header = document.querySelector('.nav-wrap');
    if (header && !header.contains(e.target as Node)) {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      mobileMenu.setAttribute('aria-hidden', 'true');
    }
  });

  // ── Mobile accordion (Services / Programs) ──
  mobileMenu.querySelectorAll<HTMLButtonElement>('.nav-mobile-accordion-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const submenu = btn.closest('li')!.querySelector<HTMLElement>('.nav-mobile-submenu')!;
      const isOpen = submenu.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
    });
  });
</script>
