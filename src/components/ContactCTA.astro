---
interface Props {
  headline?: string;
  sub?: string;
  invert?: boolean;
}

const {
  headline = "Let's build\nsomething together.",
  sub = "We're currently accepting new projects. Tell us what you're working on.",
  invert = true,
} = Astro.props;
---

<section class:list={['cta-section', { 'inv-block': invert }]}>
  <div class="container cta-inner">
    <div class="cta-text">
      <p class="t-label section-num" class:list={[{ 'inv': invert }]}>Start a Project</p>
      <h2 class="t-h1 cta-headline">{headline}</h2>
      <p class="t-body cta-sub">{sub}</p>
    </div>
    <div class="cta-actions">
      <a href="/contact" class:list={['btn', invert ? 'btn--outline-inv' : 'btn--primary']}>
        Get In Touch
      </a>
      <a href="mailto:hello@hs108.in" class:list={['btn', invert ? 'btn--primary' : 'btn--outline']}>
        hello@hs108.in
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    border-top: var(--border-width) solid var(--border);
  }

  .inv-block {
    border-top-color: transparent;
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 3rem;
    padding-top: var(--space-section);
    padding-bottom: var(--space-section);
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 700px;
  }

  .cta-headline {
    white-space: pre-line;
  }

  .cta-sub {
    max-width: 50ch;
    opacity: 0.65;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .cta-inner {
      grid-template-columns: 1fr;
    }

    .cta-actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
