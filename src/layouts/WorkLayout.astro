---
import BaseLayout from './BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  client: string;
  year: number;
  categories: string[];
  tags: string[];
  coverImage: string;
  coverAlt: string;
  color: string;
  outcome: { label: string; value: string };
  summary: string;
  services: string[];
  duration?: string;
  slug: string;
}

const {
  title, client, year, categories, tags,
  coverImage, coverAlt, color, outcome,
  summary, services, duration, slug,
} = Astro.props;

// Find next project for navigation
const allWork = await getCollection('work', ({ data }) => !data.draft);
const sorted  = allWork.sort((a, b) => a.data.order - b.data.order);
const currentIdx = sorted.findIndex(e => e.slug === slug);
const nextEntry = sorted[(currentIdx + 1) % sorted.length];

// Services used per case study (§8)
const servicesUsedMap: Record<string, { practice: string; href: string; name: string; desc: string; deliverables: string[] }[]> = {
  'novapay': [
    {
      practice: 'CX&Identity', href: '/services/cx-identity', name: 'CX&Identity',
      desc: 'Full identity overhaul — wordmark, colour system, brand voice.',
      deliverables: ['Wordmark', 'Brand Guidelines', 'Colour System'],
    },
    {
      practice: 'WebCanvas', href: '/services/webcanvas', name: 'WebCanvas',
      desc: 'End-to-end app UI — component library, design system, Figma handoff.',
      deliverables: ['Component Library', 'Design System', 'Figma Handoff'],
    },
  ],
  'urbane-property': [
    {
      practice: 'CX&Identity', href: '/services/cx-identity', name: 'CX&Identity',
      desc: 'Wordmark, palette, and photography guidelines built for premium positioning.',
      deliverables: ['Wordmark', 'Palette', 'Photo Guidelines'],
    },
    {
      practice: 'WebCanvas', href: '/services/webcanvas', name: 'WebCanvas',
      desc: 'Editorial web platform — property pages designed to feel like a magazine.',
      deliverables: ['Web Design', 'Editorial Layout', 'CMS Templates'],
    },
    {
      practice: 'WebCanvas', href: '/services/webcanvas', name: 'WebCanvas',
      desc: 'Inquiry flow redesigned from a generic form to a curated conversation.',
      deliverables: ['UX Flow', 'Form Design', 'Prototype'],
    },
  ],
  'healthos': [
    {
      practice: 'WebCanvas', href: '/services/webcanvas', name: 'WebCanvas',
      desc: '340+ component design system with full accessibility compliance.',
      deliverables: ['Design System', 'Component Library', 'A11y Audit'],
    },
    {
      practice: 'WebCanvas', href: '/services/webcanvas', name: 'WebCanvas',
      desc: 'Dev handoff package adopted by a 12-person engineering team in 6 weeks.',
      deliverables: ['Dev Handoff', 'Figma Tokens', 'Documentation'],
    },
  ],
};

const caseStudyServices = servicesUsedMap[slug] ?? [];
---

<BaseLayout title={`${title} — ${client}`} description={summary}>
  <!-- Case study header -->
  <div class="cs-header">
    <div class="container">
      <div class="cs-meta">
        <span class="tag">{client}</span>
        <span class="tag">{year}</span>
        {duration && <span class="tag">{duration}</span>}
      </div>

      <h1 class="t-h1 cs-title">{title}</h1>

      <div class="cs-summary-row">
        <p class="t-large cs-summary">{summary}</p>
        <div class="cs-outcome">
          <p class="t-label outcome-label">{outcome.label}</p>
          <p class="cs-outcome-value">{outcome.value}</p>
        </div>
      </div>

      <div class="cs-tags">
        {categories.map(c => <span class="tag">{c}</span>)}
        {tags.map(t => <span class="tag tag-sm">{t}</span>)}
      </div>

      <div class="cs-services">
        <p class="t-label cs-services-label">Services</p>
        <ul class="cs-services-list">
          {services.map(s => <li class="t-mono">{s}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <hr />

  <!-- Hero image -->
  {coverImage && (
    <div class="cs-hero-img" style={`background-color: ${color}20`}>
      <img src={coverImage} alt={coverAlt} class="img-raw" loading="eager" />
    </div>
  )}

  <!-- MDX body -->
  <div class="container cs-body">
    <div class="prose">
      <slot />
    </div>
  </div>

  <!-- Field Notes capture (§12) -->
  <div class="container fn-capture-wrap">
    <div class="field-notes-capture">
      <p class="eyebrow">Field Notes</p>
      <p class="fn-heading">Thinking from the studio, occasionally.</p>
      <p class="fn-sub">No pitch. Just the work we find worth writing about.</p>
      <form class="fn-form" action="#" method="POST">
        <input type="email" name="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>

  <hr />

  <!-- Services used (§8) -->
  {caseStudyServices.length > 0 && (
    <div class="container services-used-wrap">
      <section class="services-used">
        <div class="section-divider">
          <span class="section-divider-label">Services used on this project</span>
          <div class="section-divider-line"></div>
        </div>
        <div class:list={['services-grid', `count-${caseStudyServices.length}`]}>
          {caseStudyServices.map(svc => (
            <a href={svc.href} class="service-card">
              <div class="service-card-top">
                <span class="service-tag">{svc.practice}</span>
                <svg class="service-arrow" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M5 15L15 5M15 5H7M15 5V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="service-card-name">{svc.name}</div>
              <div class="service-card-description">{svc.desc}</div>
              <div class="service-card-footer">
                <div class="service-deliverables">
                  {svc.deliverables.map(d => <span class="deliverable-tag">{d}</span>)}
                </div>
                <span class="service-link-label">Full practice →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  )}

  <hr />

  <!-- Next project -->
  {nextEntry && (
    <div class="cs-next container">
      <p class="t-label section-num">Next Project</p>
      <a href={`/work/${nextEntry.slug}`} class="cs-next-link">
        <span class="t-h2">{nextEntry.data.title}</span>
        <span class="cs-next-arrow">→</span>
      </a>
    </div>
  )}

  <ContactCTA />
</BaseLayout>

<style>
  .cs-header {
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .cs-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1.5rem;
  }

  .cs-title {
    margin-bottom: 2rem;
  }

  .cs-summary-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .cs-summary {
    max-width: 60ch;
    opacity: 0.75;
  }

  .cs-outcome {
    text-align: right;
    flex-shrink: 0;
  }

  .outcome-label {
    opacity: 0.4;
    margin-bottom: 0.25rem;
  }

  .cs-outcome-value {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 2rem;
  }

  .tag-sm {
    opacity: 0.5;
  }

  .cs-services {
    display: flex;
    align-items: baseline;
    gap: 2rem;
  }

  .cs-services-label {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .cs-services-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .cs-services-list li {
    position: relative;
  }

  .cs-services-list li:not(:last-child)::after {
    content: '/';
    margin-left: 0.5rem;
    opacity: 0.3;
  }

  .cs-hero-img {
    width: 100%;
    max-height: 70vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cs-body {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .cs-next {
    padding-top: 3rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 0;
    border-top: var(--border-width) solid var(--border);
    border-bottom: var(--border-width) solid var(--border);
    transition: background var(--transition), padding-inline var(--transition);
  }

  .cs-next-link:hover {
    background: var(--c-yellow);
    padding-inline: 1.5rem;
  }

  .cs-next-arrow {
    font-family: var(--font-display);
    font-size: 2rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cs-summary-row {
      grid-template-columns: 1fr;
    }

    .cs-outcome {
      text-align: left;
    }

    .cs-services {
      flex-direction: column;
      gap: 0.75rem;
    }
  }

  /* ── Field Notes capture (§12) ── */
  .fn-capture-wrap {
    padding-top: var(--sp-6, 48px);
    padding-bottom: var(--sp-6, 48px);
  }

  .field-notes-capture {
    padding: var(--sp-6, 48px) 0;
    border-top: 1px solid var(--color-border);
    max-width: 480px;
  }

  .fn-heading {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: var(--sp-2, 8px) 0 var(--sp-2, 8px);
  }

  .fn-sub {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: var(--sp-4, 24px);
  }

  .fn-form {
    display: flex;
    gap: var(--sp-2, 8px);
  }

  .fn-form input[type="email"] {
    flex: 1;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-bg-surface);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color var(--dur-fast, 150ms);
  }

  .fn-form input:focus {
    border-color: var(--color-text-primary);
  }

  .fn-form button {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    padding: 10px 18px;
    background: var(--color-text-primary);
    color: var(--color-bg-surface);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: opacity var(--dur-fast, 150ms);
  }

  .fn-form button:hover {
    opacity: 0.85;
  }

  /* ── Services used (§8) ── */
  .services-used-wrap {
    padding-top: var(--sp-6, 48px);
    padding-bottom: var(--sp-6, 48px);
  }

  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--sp-4, 24px);
    margin-bottom: var(--sp-5, 32px);
  }

  .section-divider-label {
    font-size: var(--text-xs, 10px);
    font-weight: 500;
    letter-spacing: var(--tracking-label, 0.1em);
    text-transform: uppercase;
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .section-divider-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .services-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }

  .services-grid.count-1 { grid-template-columns: 1fr; }
  .services-grid.count-2 { grid-template-columns: repeat(2, 1fr); }
  .services-grid.count-3 { grid-template-columns: repeat(3, 1fr); }

  .service-card {
    background: var(--color-bg-surface);
    padding: var(--sp-5, 32px);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4, 24px);
    transition: background var(--dur-fast, 150ms);
    position: relative;
  }

  .service-card:hover {
    background: var(--color-bg-subtle);
  }

  .service-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .service-tag {
    font-size: var(--text-xs, 10px);
    font-weight: 500;
    letter-spacing: var(--tracking-label, 0.1em);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .service-arrow {
    width: 18px;
    height: 18px;
    color: var(--color-text-faint);
    transition: transform var(--dur-base, 250ms) var(--ease-out, cubic-bezier(0,0,0.2,1)), color var(--dur-fast, 150ms);
    flex-shrink: 0;
  }

  .service-card:hover .service-arrow {
    transform: translate(3px, -3px);
    color: var(--color-text-primary);
  }

  .service-card-name {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--color-text-primary);
  }

  .service-card-description {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.55;
    flex: 1;
  }

  .service-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3, 16px);
    padding-top: var(--sp-3, 16px);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .service-deliverables {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .deliverable-tag {
    font-size: 11px;
    color: var(--color-text-faint);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    padding: 3px 8px;
    border-radius: 20px;
  }

  .service-link-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--dur-fast, 150ms);
  }

  .service-card:hover .service-link-label {
    color: var(--color-text-primary);
  }

  @media (max-width: 768px) {
    .services-grid.count-2,
    .services-grid.count-3 { grid-template-columns: 1fr; }
  }
</style>
