---
import BaseLayout from './BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  client: string;
  year: number;
  categories: string[];
  tags: string[];
  coverImage: string;
  coverAlt: string;
  color: string;
  outcome: { label: string; value: string };
  summary: string;
  services: string[];
  duration?: string;
  slug: string;
}

const {
  title, client, year, categories, tags,
  coverImage, coverAlt, color, outcome,
  summary, services, duration, slug,
} = Astro.props;

// Find next project for navigation
const allWork = await getCollection('work', ({ data }) => !data.draft);
const sorted  = allWork.sort((a, b) => a.data.order - b.data.order);
const currentIdx = sorted.findIndex(e => e.slug === slug);
const nextEntry = sorted[(currentIdx + 1) % sorted.length];
---

<BaseLayout title={`${title} — ${client}`} description={summary}>
  <!-- Case study header -->
  <div class="cs-header">
    <div class="container">
      <div class="cs-meta">
        <span class="tag">{client}</span>
        <span class="tag">{year}</span>
        {duration && <span class="tag">{duration}</span>}
      </div>

      <h1 class="t-h1 cs-title">{title}</h1>

      <div class="cs-summary-row">
        <p class="t-large cs-summary">{summary}</p>
        <div class="cs-outcome">
          <p class="t-label outcome-label">{outcome.label}</p>
          <p class="cs-outcome-value">{outcome.value}</p>
        </div>
      </div>

      <div class="cs-tags">
        {categories.map(c => <span class="tag">{c}</span>)}
        {tags.map(t => <span class="tag tag-sm">{t}</span>)}
      </div>

      <div class="cs-services">
        <p class="t-label cs-services-label">Services</p>
        <ul class="cs-services-list">
          {services.map(s => <li class="t-mono">{s}</li>)}
        </ul>
      </div>
    </div>
  </div>

  <hr />

  <!-- Hero image -->
  {coverImage && (
    <div class="cs-hero-img" style={`background-color: ${color}20`}>
      <img src={coverImage} alt={coverAlt} class="img-raw" loading="eager" />
    </div>
  )}

  <!-- MDX body -->
  <div class="container cs-body">
    <div class="prose">
      <slot />
    </div>
  </div>

  <hr />

  <!-- Next project -->
  {nextEntry && (
    <div class="cs-next container">
      <p class="t-label section-num">Next Project</p>
      <a href={`/work/${nextEntry.slug}`} class="cs-next-link">
        <span class="t-h2">{nextEntry.data.title}</span>
        <span class="cs-next-arrow">→</span>
      </a>
    </div>
  )}

  <ContactCTA />
</BaseLayout>

<style>
  .cs-header {
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .cs-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1.5rem;
  }

  .cs-title {
    margin-bottom: 2rem;
  }

  .cs-summary-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: start;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .cs-summary {
    max-width: 60ch;
    opacity: 0.75;
  }

  .cs-outcome {
    text-align: right;
    flex-shrink: 0;
  }

  .outcome-label {
    opacity: 0.4;
    margin-bottom: 0.25rem;
  }

  .cs-outcome-value {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 2rem;
  }

  .tag-sm {
    opacity: 0.5;
  }

  .cs-services {
    display: flex;
    align-items: baseline;
    gap: 2rem;
  }

  .cs-services-label {
    opacity: 0.4;
    flex-shrink: 0;
  }

  .cs-services-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .cs-services-list li {
    position: relative;
  }

  .cs-services-list li:not(:last-child)::after {
    content: '/';
    margin-left: 0.5rem;
    opacity: 0.3;
  }

  .cs-hero-img {
    width: 100%;
    max-height: 70vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cs-body {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .cs-next {
    padding-top: 3rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 0;
    border-top: var(--border-width) solid var(--border);
    border-bottom: var(--border-width) solid var(--border);
    transition: background var(--transition), padding-inline var(--transition);
  }

  .cs-next-link:hover {
    background: var(--c-yellow);
    padding-inline: 1.5rem;
  }

  .cs-next-arrow {
    font-family: var(--font-display);
    font-size: 2rem;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .cs-summary-row {
      grid-template-columns: 1fr;
    }

    .cs-outcome {
      text-align: left;
    }

    .cs-services {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
