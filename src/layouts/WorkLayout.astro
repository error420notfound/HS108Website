---
import BaseLayout from './BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  client: string;
  year: number;
  categories: string[];
  tags: string[];
  coverImage: string;
  coverAlt: string;
  color: string;
  outcome: { label: string; value: string };
  summary: string;
  services: string[];
  duration?: string;
  slug: string;
  pullQuote?: string;
  stats?: { label: string; value: string }[];
  images?: { src: string; caption?: string }[];
}

const {
  title, client, year, categories, tags,
  coverImage, coverAlt, color, outcome,
  summary, services, duration, slug,
  pullQuote, stats, images,
} = Astro.props;

// Find next project for navigation
const allWork = await getCollection('work', ({ data }) => !data.draft);
const sorted  = allWork.sort((a, b) => a.data.order - b.data.order);
const currentIdx = sorted.findIndex(e => e.slug === slug);
const nextEntry = sorted[(currentIdx + 1) % sorted.length];
---

<BaseLayout title={`${title} — ${client}`} description={summary}>

  <!-- Full-bleed hero -->
  <div class="cs-hero" id="cs-hero">
    <div class="cs-hero-overlay" style={`background-color: ${color}26`}></div>
    <img src={coverImage} alt={coverAlt} class="cs-hero-img img-raw" id="cs-hero-img" loading="eager" />
    <div class="cs-hero-gradient-blend-mix"></div>
    <div class="cs-hero-gradient"></div>
    <div class="cs-hero-caption container">
      <p class="t-label cs-hero-client">{client} &mdash; {year}</p>
      <h1 class="cs-hero-title">{title}</h1>
      <p class="cs-hero-scroll t-label">Scroll to read &darr;</p>
    </div>
  </div>

  <!-- Sticky compact meta bar (hidden until past hero) -->
  <div class="cs-meta-bar" id="cs-meta-bar" aria-hidden="true">
    <div class="cs-meta-bar-inner container">
      <div class="cs-meta-item">
        <span class="cs-meta-label">Client</span>
        <span class="cs-meta-value">{client}</span>
      </div>
      <div class="cs-meta-item">
        <span class="cs-meta-label">Year</span>
        <span class="cs-meta-value">{year}</span>
      </div>
      {duration && (
        <div class="cs-meta-item">
          <span class="cs-meta-label">Duration</span>
          <span class="cs-meta-value">{duration}</span>
        </div>
      )}
      <div class="cs-meta-item cs-meta-item--services">
        <span class="cs-meta-label">Services</span>
        <span class="cs-meta-value">{services.join(', ')}</span>
      </div>
      <div class="cs-meta-item cs-meta-item--outcome">
        <span class="cs-meta-label">{outcome.label}</span>
        <span class="cs-meta-value cs-meta-outcome">{outcome.value}</span>
      </div>
    </div>
  </div>

  <!-- Stats strip (if present) -->
  {stats && stats.length > 0 && (
    <div class="cs-stats-strip">
      {stats.map(s => (
        <div class="cs-stat-cell">
          <p class="t-label cs-stat-label">{s.label}</p>
          <p class="cs-stat-value">{s.value}</p>
        </div>
      ))}
    </div>
  )}

  <!-- Case study body — full-width manifesto layout -->
  <div class="cs-body container">

    <!-- Summary intro -->
    <div class="cs-intro">
      <p class="cs-summary">{summary}</p>
    </div>

    <hr class="cs-rule" />

    <!-- Pull quote (if present) -->
    {pullQuote && (
      <div class="cs-pullquote-wrap">
        <blockquote class="cs-pullquote-text">{pullQuote}</blockquote>
      </div>
    )}

    <!-- Prose content from MDX -->
    <div class="prose cs-prose">
      <slot />
    </div>

    <!-- Image gallery (if present) -->
    {images && images.length > 0 && (
      <div class="cs-gallery">
        {images.map(img => (
          <figure class="cs-gallery-item">
            <img src={img.src} alt={img.caption ?? ''} class="img-raw cs-gallery-img" loading="lazy" />
            {img.caption && <figcaption class="t-label cs-gallery-caption">{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

  </div>

  <hr />

  <!-- Next project -->
  {nextEntry && (
    <div class="cs-next container">
      <p class="t-label cs-next-label">Next Project</p>
      <a href={`/work/${nextEntry.slug}`} class="cs-next-link">
        <span class="cs-next-title">{nextEntry.data.title}</span>
        <span class="cs-next-arrow">&rarr;</span>
      </a>
    </div>
  )}

  <ContactCTA />
</BaseLayout>

<style>
  /* ── Hero ── */
  .cs-hero {
    position: relative;
    height: 100lvh;
    overflow: hidden;
    border-bottom: var(--border-width) solid var(--border);
  }

  .cs-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .cs-hero-img {
    width: 100%;
    height: 115%;
    object-fit: cover;
    display: block;
    will-change: transform;
  }

  .cs-hero-gradient-blend-mix {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: 
      color-mix(in oklch, var(--orange-950) 100%, transparent) 100%;
    mix-blend-mode: hue;
    
  }

    .cs-hero-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
  to top,
  color-mix(in oklch, var(--orange-800) 80%, transparent) 0%,
  color-mix(in oklch, var(--orange-800) 50%, transparent) 40%,
  color-mix(in oklch, var(--orange-800) 20%, transparent) 100%
    );
  }


  .cs-hero-caption {
    position: absolute;
    bottom: 3rem;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cs-hero-client {
    color: var(--surface-base);
    opacity: 0.6;
  }

  .cs-hero-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3rem, 8vw, 7rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--surface-base);
    max-width: 18ch;
    overflow: hidden;
  }

  .cs-hero-scroll {
    color: var(--surface-base);
    opacity: 0.4;
    margin-top: 1rem;
  }

  /* ── Sticky meta bar ── */
  .cs-meta-bar {
    position: sticky;
    top: var(--nav-height, 64px);
    z-index: 10;
    background: var(--surface-base);
    border-bottom: var(--border-width) solid var(--border);
    height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .cs-meta-bar.is-visible {
    height: auto;
    opacity: 1;
    pointer-events: auto;
  }

  .cs-meta-bar-inner {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .cs-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .cs-meta-item--services {
    flex: 1;
    min-width: 0;
  }

  .cs-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.4;
  }

  .cs-meta-value {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cs-meta-outcome {
    color: var(--accent);
  }

  /* ── Stats strip ── */
  .cs-stats-strip {
    display: flex;
    border-bottom: var(--border-width) solid var(--border);
  }

  .cs-stat-cell {
    flex: 1;
    padding: 2rem 1.5rem;
    border-right: var(--border-width) solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cs-stat-cell:last-child {
    border-right: none;
  }

  .cs-stat-label {
    opacity: 0.4;
  }

  .cs-stat-value {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  /* ── Body ── */
  .cs-body {
    padding-top: clamp(3rem, 6vw, 6rem);
    padding-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 120ch;
    margin-left: auto;
    margin-right: auto;
    background-color: color-mix(in oklch, var(--surface-base) 100%, var(--accent) 20%)
  }

  /* ── Summary intro ── */
  .cs-intro {
    margin-bottom: 3rem;
  }

  .cs-summary {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.75;
    opacity: 0.75;
    max-width: 65ch;
  }

  .cs-rule {
    border: none;
    border-top: var(--border-width) solid var(--border);
    margin-bottom: 4rem;
  }

  /* ── Pull quote ── */
  .cs-pullquote-wrap {
    position: relative;
    margin-bottom: 4rem;
    /* padding-bottom: 4rem;
    /* border-bottom: var(--border-width) solid var(--border); */
  }

  .cs-pullquote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.4rem, 4vw, 3.5rem);
    letter-spacing: -0.02em;
    line-height: 1.4;
    color: var(--accent-strong);
    max-width: 30ch;
    margin: 0;
    padding: 0;
    border: none;
  }

  /* ── Prose ── */
  .cs-prose {
    counter-reset: chapter;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    padding-top: 3rem;
    border-top: var(--border-width) solid var(--border);
    counter-increment: chapter;
  }

  .prose :global(h2::before) {
    display: block;
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.3;
    margin-bottom: 0.75rem;
    content: "0" counter(chapter) ".";
  }

  .prose :global(h3) {
    font-family: var(--font-mono);
    font-size: var(--size-label);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    opacity: 0.55;
  }

  .prose :global(p) {
    font-size: var(--size-large);
    line-height: 1.75;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .prose :global(li) {
    font-size: var(--size-large);
    line-height: 1.6;
    opacity: 0.8;
  }

  .prose :global(blockquote) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--accent-strong);
    margin: 3rem 0;
    padding: 0;
    border: none;
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    display: block;
    border: var(--border-width) solid var(--border);
    margin: 3rem 0;
  }

  /* ── Gallery ── */
  .cs-gallery {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cs-gallery-item {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    
    /* border-bottom: var(--border-width) solid var(--border); */
  }

  .cs-gallery-item:first-child {
    border-top: none;
  }

  .cs-gallery-img {
    width: auto;
    max-width: 100%;
    max-height: 50vh;
    border-top: var(--border-width) solid var(--border);
    display: block;
  }

  .cs-gallery-caption {
    padding: 0.75rem 0;
    opacity: 0.4;
    padding-bottom: 3rem;
  }

  /* ── Next project ── */
  .cs-next {
    padding-top: 3rem;
    padding-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .cs-next-label {
    opacity: 0.4;
  }

  .cs-next-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 0;
    border-top: var(--border-width) solid var(--border);
    border-bottom: var(--border-width) solid var(--border);
    transition: background var(--transition), padding-inline var(--transition);
  }

  .cs-next-link:hover {
    background: var(--accent);
    padding-inline: 1.5rem;
    color: var(--surface-base);
  }

  .cs-next-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .cs-next-arrow {
    font-family: var(--font-display);
    font-size: 2rem;
    flex-shrink: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .cs-hero {
      height: 80lvh;
    }

    .cs-hero-title {
      font-size: clamp(2.5rem, 9vw, 4rem);
    }

    .cs-meta-bar-inner {
      gap: 1.5rem;
    }

    .cs-meta-item--services {
      display: none;
    }

    .cs-stats-strip {
      flex-direction: column;
    }

    .cs-stat-cell {
      border-right: none;
      border-bottom: var(--border-width) solid var(--border);
    }

    .cs-stat-cell:last-child {
      border-bottom: none;
    }

    .cs-body {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .cs-meta-bar-inner {
      gap: 1.25rem;
    }

    .cs-meta-item--outcome {
      flex-shrink: 0;
    }
  }
</style>

<script>
  // Parallax on hero image
  const heroImg = document.getElementById('cs-hero-img') as HTMLImageElement | null;
  if (heroImg) {
    let ticking = false;
    const update = () => {
      const scrollY = window.scrollY;
      heroImg.style.transform = `translateY(${scrollY * 0.3}px)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }

  // Sticky meta bar — show after hero
  const hero = document.getElementById('cs-hero');
  const metaBar = document.getElementById('cs-meta-bar');
  if (hero && metaBar) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          metaBar.classList.add('is-visible');
          metaBar.removeAttribute('aria-hidden');
        } else {
          metaBar.classList.remove('is-visible');
          metaBar.setAttribute('aria-hidden', 'true');
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(hero);
  }

  // Hero title line-wipe entrance
  import { animate, inView } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  const heroTitle = document.querySelector<HTMLElement>('.cs-hero-title');
  if (heroTitle) {
    heroTitle.style.transform = 'translateY(100%)';
    heroTitle.style.opacity = '0';
    // Small delay so font loads
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroTitle, { transform: ['translateY(40px)', 'translateY(0px)'], opacity: [0, 1] }, { duration: 0.9, easing: ease, delay: 0.15 });
    }, 50);
  }

  const heroClient = document.querySelector<HTMLElement>('.cs-hero-client');
  if (heroClient) {
    heroClient.style.opacity = '0';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroClient, { opacity: [0, 1] }, { duration: 0.6, easing: ease });
    }, 50);
  }

  const heroScroll = document.querySelector<HTMLElement>('.cs-hero-scroll');
  if (heroScroll) {
    heroScroll.style.opacity = '0';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroScroll, { opacity: [0, 0.4] }, { duration: 0.6, easing: ease, delay: 0.5 });
    }, 50);
  }

  // Summary fade in
  const summary = document.querySelector<HTMLElement>('.cs-summary');
  if (summary) {
    summary.style.opacity = '0';
    inView(summary, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(summary, { opacity: [0, 0.75], transform: ['translateY(20px)', 'translateY(0)'] }, { duration: 0.7, easing: ease });
    }, { amount: 0.2 });
  }

  // Pull quote wipe-in
  const pq = document.querySelector<HTMLElement>('.cs-pullquote-text');
  if (pq) {
    pq.style.transform = 'translateY(30px)';
    pq.style.opacity = '0';
    inView(pq, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(pq, { transform: ['translateY(30px)', 'translateY(0)'], opacity: [0, 1] }, { duration: 0.8, easing: ease });
    }, { amount: 0.2 });
  }

  // Prose h2 headings wipe-in
  document.querySelectorAll<HTMLElement>('.prose h2').forEach((h) => {
    h.style.opacity = '0';
    h.style.transform = 'translateY(24px)';
    inView(h, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(h, { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0)'] }, { duration: 0.7, easing: ease });
    }, { amount: 0.3 });
  });
</script>
