---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import WorkCard from '@components/WorkCard.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { getCollection } from 'astro:content';

const allWork  = await getCollection('work', ({ data }) => !data.draft && data.featured);
const featured = allWork.sort((a, b) => a.data.order - b.data.order).slice(0, 3);

const services = [
  { num: '01', code: 'WebCanvas',    name: 'Digital Design',    desc: 'Web, app, UI, and UX design. Intuitive digital experiences that captivate audiences and perform at every touchpoint.' },
  { num: '02', code: 'CX&Identity',  name: 'Branding & Identity', desc: 'Logo, brand identity, and packaging design. A strong, recognisable presence that resonates with your audience and lasts.' },
  { num: '03', code: 'CMF_Nexus',    name: 'Product Design',    desc: 'From concept sketch and CAD to prototyping and production-ready files. Design meets engineering precision.' },
  { num: '04', code: 'Lumina.raw',   name: 'Photo & Video',     desc: 'Photography, videography, and editing. Visuals that tell your brand story and stop the scroll.' },
];

const programs = [
  { name: 'Creative Department', slug: 'creative-department', desc: 'Our flagship retainer — embedded design support for businesses that need design ongoing, not one-off.' },
  { name: 'Design Lab',          slug: 'design-lab',          desc: 'Research and discovery for complex, high-demand design challenges before execution begins.' },
  { name: 'off_menu',            slug: 'off-menu',            desc: 'Bespoke, tailor-made packages for clients whose needs don\'t fit a standard scope.' },
  { name: 'Field Notes',         slug: 'field-notes',         desc: 'Our platform for discourse with designers, artisans, and industry experts.' },
];
---

<BaseLayout title="HS108" description="HS108 is an independent design studio building brands and products that scale." glsl={true}>

  <!-- Hero (includes ticker) -->
  <Hero />

  <!-- Featured Work -->
  <section class="section container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Selected Work</p>
        <h2>What We've Built</h2>
      </div>
      <a href="/work" class="btn btn--outline">All Projects →</a>
    </div>

    <div class="featured-grid">
      {featured.map((entry, i) => (
        <div class:list={['featured-item', { 'featured-item--wide': i === 0 }]}>
          <WorkCard
            slug={entry.slug}
            title={entry.data.title}
            client={entry.data.client}
            year={entry.data.year}
            categories={entry.data.categories}
            coverImage={entry.data.coverImage}
            coverAlt={entry.data.coverAlt}
            color={entry.data.color}
            outcome={entry.data.outcome}
            summary={entry.data.summary}
            large={i === 0}
          />
        </div>
      ))}
    </div>
  </section>

  <hr />

  <!-- Services teaser -->
  <section class="section container">
    <div class="section-header">
      <div>
        <p class="eyebrow">What We Do</p>
        <h2>Our Services</h2>
      </div>
      <a href="/services" class="btn btn--outline">Full Services →</a>
    </div>

    <div class="services-list">
      {services.map(svc => (
        <div class="service-row b-top">
          <span class="t-label service-num">{svc.num}</span>
          <div class="service-name-block">
            <span class="t-label service-code">{svc.code}</span>
            <h3 class="t-h3 service-name">{svc.name}</h3>
          </div>
          <p class="t-body service-desc">{svc.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <hr />

  <!-- Process teaser -->
  <section class="section section--inv container">
    <p class="eyebrow" style="margin-bottom:1rem">How We Work</p>
    <h2 style="margin-bottom:3rem">Our Process</h2>

    <div class="process-strip stat-strip">
      {[
        { n: '01', title: 'Understand', desc: 'Deep research. Client interviews. Market mapping. We never design blind.' },
        { n: '02', title: 'Design', desc: 'Strategic concepts, iteration, and refinement until we hit something true.' },
        { n: '03', title: 'Build', desc: 'Production-ready files, handoff docs, and implementation support.' },
        { n: '04', title: 'Scale', desc: 'Systems that grow with your company. Retainers for ongoing partnership.' },
      ].map(step => (
        <div class="process-step">
          <span class="t-label process-num">{step.n}</span>
          <h3 class="t-h3 process-title">{step.title}</h3>
          <p class="t-body process-desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <div style="margin-top:3rem">
      <a href="/process" class="btn btn--outline-inv">See Full Process →</a>
    </div>
  </section>

  <hr />

  <!-- Programs -->
  <section class="section container">
    <div class="section-header">
      <div>
        <p class="eyebrow">Beyond Projects</p>
        <h2>Our Programs</h2>
      </div>
      <a href="/programs/creative-department" class="btn btn--outline">Explore Programs →</a>
    </div>

    <div class="programs-grid">
      {programs.map(prog => (
        <a href={`/programs/${prog.slug}`} class="program-card">
          <p class="program-name">{prog.name}</p>
          <p class="program-desc">{prog.desc}</p>
          <span class="program-cta">Learn More →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Field Notes capture — homepage footer (§12) -->
  <div class="container fn-home-wrap">
    <div class="field-notes-capture-home">
      <p class="eyebrow">Field Notes</p>
      <p class="fn-home-heading">Thinking from the studio, occasionally.</p>
      <p class="fn-home-sub">No pitch. Just the work we find worth writing about.</p>
      <form class="fn-home-form" action="#" method="POST">
        <input type="email" name="email" placeholder="your@email.com" required />
        <button type="submit">Subscribe</button>
      </form>
    </div>
  </div>

  <ContactCTA />

</BaseLayout>


<style>
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .section-header .t-h2 {
    margin-top: 0.5rem;
  }

  /* Featured work grid */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: var(--space-gap);
  }

  .featured-item {
    grid-column: span 6;
  }

  .featured-item--wide {
    grid-column: span 12;
  }

  /* Services */
  .services-list {
    display: flex;
    flex-direction: column;
  }

  .service-row {
    display: grid;
    grid-template-columns: 3rem 1fr 2fr;
    gap: 2rem;
    padding: 2rem 0;
    align-items: start;
    border-bottom: var(--border-width) solid var(--border);
  }

  .service-num {
    opacity: 0.35;
    padding-top: 4px;
  }

  .service-name-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .service-code {
    opacity: 0.45;
    color: var(--accent);
  }

  .service-desc {
    opacity: 0.6;
    max-width: 60ch;
  }

  /* Process */
  .process-strip {
    border-top-color: var(--border-inv);
    border-left-color: var(--border-inv);
  }

  .process-step {
    border-right: var(--border-width) solid var(--border-inv);
    border-bottom: var(--border-width) solid var(--border-inv);
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .process-num {
    opacity: 0.4;
  }

  .process-title {
    color: var(--c-yellow);
  }

  .process-desc {
    opacity: 0.6;
  }

  /* Programs */
  .programs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-gap);
  }

  .program-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: var(--sp-5, 32px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    transition: border-color var(--dur-fast, 150ms), background var(--dur-fast, 150ms);
  }

  .program-card:hover {
    border-color: var(--color-border-mid);
    background: var(--color-bg-subtle);
  }

  .program-name {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .program-desc {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    flex: 1;
  }

  .program-cta {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: auto;
    transition: color var(--dur-fast, 150ms);
  }

  .program-card:hover .program-cta {
    color: var(--color-text-primary);
  }

  @media (max-width: 900px) {
    .featured-item {
      grid-column: span 12;
    }

    .service-row {
      grid-template-columns: 3rem 1fr;
    }

    .service-desc {
      grid-column: 2;
    }

    .programs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .service-row {
      grid-template-columns: 1fr;
    }

    .programs-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Field Notes capture */
  .fn-home-wrap {
    padding-top: var(--sp-6, 48px);
    padding-bottom: var(--sp-6, 48px);
  }

  .field-notes-capture-home {
    padding: var(--sp-6, 48px) 0;
    border-top: 1px solid var(--color-border);
    max-width: 480px;
  }

  .fn-home-heading {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: var(--sp-2, 8px) 0;
  }

  .fn-home-sub {
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: var(--sp-4, 24px);
  }

  .fn-home-form {
    display: flex;
    gap: var(--sp-2, 8px);
  }

  .fn-home-form input[type="email"] {
    flex: 1;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: var(--color-bg-surface);
    color: var(--color-text-primary);
    outline: none;
    transition: border-color var(--dur-fast, 150ms);
  }

  .fn-home-form input:focus {
    border-color: var(--color-text-primary);
  }

  .fn-home-form button {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    padding: 10px 18px;
    background: var(--color-text-primary);
    color: var(--color-bg-surface);
    border: none;
    border-radius: 3px;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: opacity var(--dur-fast, 150ms);
  }

  .fn-home-form button:hover {
    opacity: 0.85;
  }
</style>
