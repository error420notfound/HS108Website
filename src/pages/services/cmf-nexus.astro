---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const deliverables = [
  { group: 'Concept & Ideation', items: ['Industrial design sketches', 'Concept exploration & selection', 'Ergonomics & human factors research', 'Form language development', 'Design intent documentation'] },
  { group: 'Engineering Design', items: ['3D CAD modelling (SolidWorks/Fusion)', 'CMF specification (colour, material, finish)', 'Design for manufacture (DFM) review', 'Tolerancing & assembly planning', 'Technical drawings & BOM support'] },
  { group: 'Prototyping', items: ['Appearance models & soft mockups', 'Functional prototypes', 'User testing models', 'Pre-production samples', 'Production-ready design files'] },
];

const process = [
  { n: '01', title: 'Research', desc: 'User needs, market context, manufacturing constraints — understanding all inputs before anything is drawn.' },
  { n: '02', title: 'Concept', desc: 'Rapid ideation across multiple directions. Wide before narrow — we explore before we commit.' },
  { n: '03', title: 'Develop', desc: 'CAD, CMF, DFM — the work of turning concept into something buildable, manufacturable, and right.' },
  { n: '04', title: 'Deliver', desc: 'Production-ready files, documentation, and manufacturing liaison support through to first article.' },
];
---

<BaseLayout
  title="CMF_Nexus — Product Design"
  description="CMF_Nexus is HS108's product design practice — from concept sketches and CAD to prototyping and production-ready design."
  bodyClass="theme-vermilion"
>

  <!-- SECTION 1: Hero -->
  <section class="svc-hero inv-block" id="svc-hero">
    <div class="container svc-hero-inner">
      <div class="svc-hero-top">
        <span class="t-label svc-service-label">A Service by HS108</span>
        <span class="t-label svc-code">CMF_Nexus</span>
      </div>
      <div class="svc-hero-body">
        <div class="svc-hero-title-wrap">
          <h1 class="svc-hero-title">Product<br /><em>Design.</em></h1>
        </div>
        <div class="svc-hero-right">
          <p class="svc-tagline">
            From concept sketch to production-ready file. We blend design thinking with engineering rigour to develop products that look right, work right, and manufacture efficiently.
          </p>
          <div class="svc-meta-row">
            <div class="svc-meta-item">
              <span class="svc-meta-label">Timeline</span>
              <span class="svc-meta-val">8–20 weeks</span>
            </div>
            <div class="svc-meta-item">
              <span class="svc-meta-label">Output</span>
              <span class="svc-meta-val">Production-ready CAD + documentation</span>
            </div>
            <div class="svc-meta-item">
              <span class="svc-meta-label">Scope</span>
              <span class="svc-meta-val">CAD · CMF · Prototype · Production</span>
            </div>
          </div>
          <div class="svc-hero-tags">
            <span class="tag svc-tag">CAD</span>
            <span class="tag svc-tag">CMF</span>
            <span class="tag svc-tag">Prototype</span>
            <span class="tag svc-tag">Production</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Manifesto -->
  <section class="svc-section svc-manifesto">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>What We Do</p>
      <div class="svc-statement-wrap">
        <h2 class="svc-statement" data-wipe>Design that bridges<br /><em>form and factory.</em></h2>
      </div>
      <div class="svc-manifesto-body">
        <p class="svc-prose" data-fade>
          CMF_Nexus is HS108's product design practice. The name reflects the focus: Colour, Material, and Finish — the decisions that determine how a product feels, communicates, and holds up over time — brought together at the nexus of design and manufacture.
        </p>
        <p class="svc-prose" data-fade>
          We work across the full product development cycle: from early ideation and form exploration through to detailed CAD, DFM review, and production-ready deliverables.
        </p>
        <p class="svc-prose" data-fade>
          Our approach combines design intent with engineering discipline. A product should be desirable and buildable. Those aren't competing goals — they're the same goal, approached with enough rigour to get both right.
        </p>
      </div>
    </div>
  </section>

  <hr />

  <!-- SECTION 3: Deliverables -->
  <section class="svc-section svc-deliverables">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>Deliverables</p>
      <div class="del-rows">
        {deliverables.map(group => (
          <div class="del-row" data-fade>
            <div class="del-row-left">
              <p class="t-label del-group-name">{group.group}</p>
            </div>
            <ul class="del-row-items">
              {group.items.map(item => (
                <li class="t-mono del-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr />

  <!-- SECTION 4: Process -->
  <section class="svc-section svc-process">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>How We Work</p>
      <div class="process-rows">
        {process.map(step => (
          <div class="process-row" data-fade>
            <span class="process-num">{step.n}</span>
            <div class="process-content">
              <h3 class="process-title">{step.title}</h3>
              <p class="process-desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr />

  <!-- SECTION 5: CTA -->
  <section class="svc-section svc-cta inv-block">
    <div class="container svc-cta-inner">
      <div class="svc-cta-left">
        <p class="t-label svc-section-label svc-section-label--inv" data-wipe>Start a project</p>
        <h2 class="svc-cta-headline" data-wipe>
          Make something<br /><em>real and right.</em>
        </h2>
        <p class="svc-cta-sub" data-fade>
          Tell us about the product you're building — what it needs to do, who it's for, and where in the development process you are. We'll work from there.
        </p>
        <div class="svc-cta-btns" data-fade>
          <a href="/contact?domain=cmf-nexus" class="btn btn--outline-inv">Get In Touch</a>
          <a href="/services" class="btn btn--outline-inv svc-btn-ghost">← All Services</a>
        </div>
      </div>
      <div class="svc-cta-stats" data-fade>
        <div class="svc-stat">
          <span class="svc-stat-val">8–20</span>
          <span class="svc-stat-label">Weeks for full development cycle</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat-val">3D</span>
          <span class="svc-stat-label">CAD-ready files for manufacturing</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat-val">DFM</span>
          <span class="svc-stat-label">Design-for-manufacture review on every project</span>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    headline="Need the product to look as good as it works?"
    sub="CMF_Nexus pairs with CX&Identity and Lumina.raw for full product launch coverage."
    domain="cmf-nexus"
  />

</BaseLayout>

<style>
  .svc-hero { min-height: 100vh; display: flex; align-items: stretch; 
  background: linear-gradient(180deg in oklch, var(--vermilion-700) 0%, var(--vermilion-900) 70%,  var(--vermilion-950) 100%);
  }

  .svc-hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    width: 100%;
    border-bottom: var(--border-width) solid rgba(255,255,255,0.12);
  }

  .svc-hero-top { display: flex; align-items: center; gap: 1.5rem; margin-bottom: clamp(2rem, 6vw, 4rem); }
  .svc-service-label { opacity: 0.4; color: var(--text-on-dark); }
  .svc-code { color: var(--accent); }

  .svc-hero-body { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; }
  .svc-hero-title-wrap { overflow: hidden; }

  .svc-hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(4rem, 9vw, 9rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text-on-dark);
    margin: 0;
  }

  .svc-hero-title em { font-style: italic; color: var(--accent); }

  .svc-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    color: var(--text-on-dark);
    opacity: 0.7;
    max-width: 50ch;
    margin: 0 0 2rem;
  }

  .svc-meta-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: var(--border-width) solid rgba(255,255,255,0.12);
  }

  .svc-meta-item { display: flex; gap: 1rem; align-items: baseline; }

  .svc-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.35;
    color: var(--text-on-dark);
    flex-shrink: 0;
    min-width: 6ch;
  }

  .svc-meta-val {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--text-on-dark);
    opacity: 0.8;
  }

  .svc-hero-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .svc-tag { border-color: rgba(255,255,255,0.2); color: var(--text-on-dark); }

  .svc-section { padding-top: clamp(4rem, 8vw, 8rem); padding-bottom: clamp(4rem, 8vw, 8rem); }
  .svc-section-label { opacity: 0.4; margin-bottom: 2rem; display: block; }
  .svc-section-label--inv { color: var(--text-on-dark); }

  .svc-statement-wrap { overflow: hidden; margin-bottom: 4rem; }

  .svc-statement {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    max-width: 22ch;
    margin: 0;
  }

  .svc-statement em { font-style: italic; }

  .svc-manifesto-body {
    max-width: 60ch;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: clamp(0px, 10vw, 10rem);
  }

  .svc-prose { font-family: var(--font-body); font-size: var(--size-large); line-height: 1.75; opacity: 0.7; margin: 0; }

  .del-rows { display: flex; flex-direction: column; }

  .del-row {
    display: grid;
    grid-template-columns: 20ch 1fr;
    gap: 3rem;
    align-items: start;
    padding: 2.5rem 0;
    border-top: var(--border-width) solid var(--border);
  }

  .del-row:last-child { border-bottom: var(--border-width) solid var(--border); }
  .del-group-name { color: var(--accent); margin: 0; }

  .del-row-items { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; }

  .del-item { font-size: 11px; opacity: 0.65; position: relative; padding-left: 1rem; }

  .del-item::before {
    content: '—';
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.4;
  }

  .process-rows { display: flex; flex-direction: column; }

  .process-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    align-items: start;
    padding: 3rem 0;
    border-top: var(--border-width) solid var(--border);
  }

  .process-row:last-child { border-bottom: var(--border-width) solid var(--border); }

  .process-num {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(3.5rem, 6vw, 6rem);
    line-height: 1;
    letter-spacing: -0.03em;
    opacity: 0.08;
    color: var(--black-native);
    user-select: none;
  }

  .process-content { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 0.5rem; }

  .process-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--accent);
    margin: 0;
  }

  .process-desc { font-family: var(--font-body); font-size: var(--size-body); line-height: 1.65; opacity: 0.6; max-width: 55ch; margin: 0; }

  .svc-cta { min-height: 60vh; 
   background: linear-gradient(0deg in oklch, var(--vermilion-700) 0%, var(--vermilion-900) 70%,  var(--vermilion-950) 100%);
  }

  .svc-cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
    padding-top: clamp(4rem, 8vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
  }

  .svc-cta-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-on-dark);
    margin: 0 0 2rem;
  }

  .svc-cta-headline em { font-style: italic; }

  .svc-cta-sub {
    font-family: var(--font-body);
    font-size: var(--size-body);
    line-height: 1.7;
    color: var(--text-on-dark);
    opacity: 0.6;
    max-width: 45ch;
    margin: 0 0 2.5rem;
  }

  .svc-cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .svc-btn-ghost { opacity: 0.5; }

  .svc-cta-stats { display: flex; flex-direction: column; border-top: var(--border-width) solid rgba(255,255,255,0.15); }

  .svc-stat { display: flex; flex-direction: column; gap: 0.4rem; padding: 2rem 0; border-bottom: var(--border-width) solid rgba(255,255,255,0.12); }

  .svc-stat-val {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--vermilion-100);
  }

  .svc-stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--vermilion-200);
    opacity: 0.8;
  }

  @media (max-width: 900px) {
    .svc-hero-body, .svc-cta-inner { grid-template-columns: 1fr; gap: 3rem; }
    .del-row { grid-template-columns: 1fr; gap: 1rem; }
    .svc-manifesto-body { padding-left: 0; }
  }

  @media (max-width: 600px) {
    .svc-hero { min-height: 90vh; }
    .del-row-items { flex-direction: column; gap: 0.5rem; }
    .process-row { grid-template-columns: 1fr; gap: 0.5rem; }
    .process-num { font-size: 3rem; }
  }
</style>

<script>
  import { animate, inView } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  const heroTitle = document.querySelector<HTMLElement>('.svc-hero-title');
  if (heroTitle) {
    heroTitle.style.transform = 'translateY(60px)';
    heroTitle.style.opacity = '0';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroTitle, { transform: ['translateY(60px)', 'translateY(0px)'], opacity: [0, 1] }, { duration: 1.0, easing: ease, delay: 0.1 });
    }, 50);
  }

  const heroRight = document.querySelector<HTMLElement>('.svc-hero-right');
  if (heroRight) {
    heroRight.style.opacity = '0';
    heroRight.style.transform = 'translateY(24px)';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroRight, { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0px)'] }, { duration: 0.8, easing: ease, delay: 0.35 });
    }, 50);
  }

  document.querySelectorAll<HTMLElement>('[data-wipe]').forEach(el => {
    el.style.transform = 'translateY(40px)';
    el.style.opacity = '0';
    inView(el, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(el, { transform: ['translateY(40px)', 'translateY(0px)'], opacity: [0, 1] }, { duration: 0.75, easing: ease });
    }, { amount: 0.2 });
  });

  document.querySelectorAll<HTMLElement>('[data-fade]').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    inView(el, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(el, { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0px)'] }, { duration: 0.65, easing: ease, delay: i * 0.05 });
    }, { amount: 0.15 });
  });
</script>
