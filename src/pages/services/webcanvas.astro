---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const deliverables = [
  { group: 'Web Design', items: ['Marketing sites & landing pages', 'Product & SaaS web interfaces', 'CMS-ready design (Webflow, Framer, custom)', 'Responsive design across all breakpoints', 'Launch QA and developer handoff'] },
  { group: 'App & Product UI', items: ['iOS & Android app UI design', 'Dashboard & data visualisation', 'Component-level UI systems', 'Interaction & micro-animation specs', 'Design tokens for engineering'] },
  { group: 'UX', items: ['User research & interviews', 'User journey mapping', 'Information architecture', 'Wireframes & low-fidelity concepts', 'High-fidelity prototypes (Figma)'] },
];

const process = [
  { n: '01', title: 'Research', desc: 'User interviews, competitor analysis, and content audit before any screen is designed.' },
  { n: '02', title: 'Architecture', desc: 'Site map, information hierarchy, and wireframe flows aligned to user goals.' },
  { n: '03', title: 'Design', desc: 'Full high-fidelity UI — every page, every state, every breakpoint.' },
  { n: '04', title: 'Handoff', desc: 'Figma files structured for engineering. Dev tokens, annotations, and QA support.' },
];
---

<BaseLayout
  title="WebCanvas — Digital Design"
  description="WebCanvas is HS108's digital design practice — web, app, UI, and UX design for companies building digital products and experiences."
  bodyClass="theme-blue"
>

  <!-- SECTION 1: Hero — full viewport, inverted -->
  <section class="svc-hero inv-block" id="svc-hero">
    <div class="container svc-hero-inner">
      <div class="svc-hero-top">
        <span class="t-label svc-service-label">A Service by HS108</span>
        <span class="t-label svc-code">WebCanvas</span>
      </div>
      <div class="svc-hero-body">
        <div class="svc-hero-title-wrap">
          <h1 class="svc-hero-title">Digital<br /><em>Design.</em></h1>
        </div>
        <div class="svc-hero-right">
          <p class="svc-tagline">
            Intuitive digital experiences that captivate audiences and perform at every touchpoint. From the first wireframe to the final pixel.
          </p>
          <div class="svc-meta-row">
            <div class="svc-meta-item">
              <span class="svc-meta-label">Timeline</span>
              <span class="svc-meta-val">4–16 weeks</span>
            </div>
            <div class="svc-meta-item">
              <span class="svc-meta-label">Output</span>
              <span class="svc-meta-val">Production-ready Figma files</span>
            </div>
            <div class="svc-meta-item">
              <span class="svc-meta-label">Scope</span>
              <span class="svc-meta-val">Web · App · UI · UX</span>
            </div>
          </div>
          <div class="svc-hero-tags">
            <span class="tag svc-tag">Web</span>
            <span class="tag svc-tag">App</span>
            <span class="tag svc-tag">UI</span>
            <span class="tag svc-tag">UX</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Manifesto — "What We Do" -->
  <section class="svc-section svc-manifesto">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>What We Do</p>
      <div class="svc-statement-wrap">
        <h2 class="svc-statement" data-wipe>Design for screens<br />people actually use.</h2>
      </div>
      <div class="svc-manifesto-body">
        <p class="svc-prose" data-fade>
          WebCanvas is how HS108 approaches digital. It covers the full range — from the marketing site that converts visitors into believers, to the product interface that earns daily use.
        </p>
        <p class="svc-prose" data-fade>
          We don't design for Dribbble. We design for the person who lands on your page, clicks through your app, and decides whether to trust your product. That means research before execution, structure before aesthetics, and accessibility baked in from the start.
        </p>
        <p class="svc-prose" data-fade>
          Every WebCanvas project is grounded in how people actually behave — not how we hope they will.
        </p>
      </div>
      {/* <figure class="svc-figure" data-fade>
        <div class="svc-image-hue-wrap">
          <img src="/work/webcanvas-dashboard.jpg" alt="WebCanvas dashboard design interface" class="svc-image" />
        </div>
      </figure> */}
    </div>
  </section>

  <hr />

  <!-- SECTION 3: Deliverables -->
  <section class="svc-section svc-deliverables">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>Deliverables</p>
      <div class="del-rows">
        {deliverables.map(group => (
          <div class="del-row" data-fade>
            <div class="del-row-left">
              <p class="t-label del-group-name">{group.group}</p>
            </div>
            <ul class="del-row-items">
              {group.items.map(item => (
                <li class="t-mono del-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr />

  <!-- SECTION 3b: Case Study Image -->
  <section class="svc-section svc-image-block">
    <div class="container">
      {/* <figure class="svc-figure svc-figure-large" data-fade>
        <div class="svc-image-hue-wrap">
          <img src="/work/webcanvas-case-01.jpg" alt="WebCanvas case study: end-to-end digital design" class="svc-image" />
        </div>
      </figure> */}
    </div>
  </section>

  <hr />

  <!-- SECTION 4: Process -->
  <section class="svc-section svc-process">
    <div class="container">
      <p class="t-label svc-section-label" data-wipe>How We Work</p>
      <div class="process-rows">
        {process.map(step => (
          <div class="process-row" data-fade>
            <span class="process-num">{step.n}</span>
            <div class="process-content">
              <h3 class="process-title">{step.title}</h3>
              <p class="process-desc">{step.desc}</p>
            </div>
            <div class="process-rule" aria-hidden="true"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 4b: Process Image -->
  <section class="svc-section svc-image-block">
    <div class="container">
      {/* <figure class="svc-figure svc-figure-large" data-fade>
        <div class="svc-image-hue-wrap">
          <img src="/work/webcanvas-process-01.jpg" alt="WebCanvas process: from research to handoff" class="svc-image" />
        </div>
      </figure> */}
    </div>
  </section>

  <hr />

  <!-- SECTION 5: CTA — inverted -->
  <section class="svc-section svc-cta inv-block">
    <div class="container svc-cta-inner">
      <div class="svc-cta-left">
        <p class="t-label svc-section-label svc-section-label--inv" data-wipe>Start a project</p>
        <h2 class="svc-cta-headline" data-wipe>
          Let's build something<br /><em>people use every day.</em>
        </h2>
        <p class="svc-cta-sub" data-fade>
          Tell us what you're building — a new site, an app redesign, or a product that doesn't exist yet. We'll scope it together.
        </p>
        <div class="svc-cta-btns" data-fade>
          <a href="/contact" class="btn btn--outline-inv">Get In Touch</a>
          <a href="/services" class="btn btn--outline-inv svc-btn-ghost">← All Services</a>
        </div>
      </div>
      <div class="svc-cta-stats" data-fade>
        <div class="svc-stat">
          <span class="svc-stat-val">4–16</span>
          <span class="svc-stat-label">Weeks typical engagement</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat-val">100%</span>
          <span class="svc-stat-label">Figma — no black box tools</span>
        </div>
        <div class="svc-stat">
          <span class="svc-stat-val">0</span>
          <span class="svc-stat-label">Templates. Everything is made for you.</span>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA
    headline="Need more than digital?"
    sub="WebCanvas is one of four HS108 practices. Explore branding, product design, and visual production."
  />

</BaseLayout>

<style>
  /* ── HERO ── */
  .svc-hero {
    min-height: 100vh;
    display: flex;
    align-items: stretch;
    padding-top: 0;
    padding-bottom: 0;
  }

  .svc-hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: clamp(6rem, 12vw, 10rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    width: 100%;
    border-bottom: var(--border-width) solid rgba(255,255,255,0.12);
  }

  .svc-hero-top {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: clamp(2rem, 6vw, 4rem);
  }

  .svc-service-label {
    opacity: 0.4;
    color: var(--text-on-dark);
  }

  .svc-code {
    color: var(--accent);
  }

  .svc-hero-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }

  .svc-hero-title-wrap {
    overflow: hidden;
  }

  .svc-hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(4rem, 9vw, 9rem);
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--text-on-dark);
    margin: 0;
  }

  .svc-hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .svc-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    color: var(--text-on-dark);
    opacity: 0.7;
    max-width: 50ch;
    margin: 0 0 2rem;
  }

  .svc-meta-row {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: var(--border-width) solid rgba(255,255,255,0.12);
  }

  .svc-meta-item {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .svc-meta-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.35;
    color: var(--text-on-dark);
    flex-shrink: 0;
    min-width: 6ch;
  }

  .svc-meta-val {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    color: var(--text-on-dark);
    opacity: 0.8;
  }

  .svc-hero-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .svc-tag {
    border-color: rgba(255,255,255,0.2);
    color: var(--text-on-dark);
  }

  /* ── IMAGES ──
  .svc-figure {
    margin: 0;
    padding: 0;
  }

  .svc-figure-large {
    margin-top: 3rem;
    margin-bottom: 3rem;
  }

  .svc-image-hue-wrap {
    position: relative;
    background: var(--accent);
    border: var(--border-width) solid var(--border);
  }

  .svc-image-hue-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--accent);
    mix-blend-mode: saturation;
    pointer-events: none;
  }

  .svc-image {
    width: 100%;
    height: auto;
    display: block;
    position: relative;
    z-index: 1;
  }
  */

  /* ── SECTIONS ── */
  .svc-section {
    padding-top: clamp(4rem, 8vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
  }

  .svc-section-label {
    opacity: 0.4;
    margin-bottom: 2rem;
    display: block;
  }

  .svc-section-label--inv {
    color: var(--text-on-dark);
  }

  /* ── MANIFESTO ── */
  .svc-statement-wrap {
    overflow: hidden;
    margin-bottom: 4rem;
  }

  .svc-statement {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    max-width: 22ch;
    margin: 0;
  }

  .svc-manifesto-body {
    max-width: 60ch;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-left: clamp(0px, 10vw, 10rem);
  }

  .svc-prose {
    font-family: var(--font-body);
    font-size: var(--size-large);
    line-height: 1.75;
    opacity: 0.7;
    margin: 0;
  }

  /* ── DELIVERABLES ── */
  .del-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .del-row {
    display: grid;
    grid-template-columns: 20ch 1fr;
    gap: 3rem;
    align-items: start;
    padding: 2.5rem 0;
    border-top: var(--border-width) solid var(--border);
  }

  .del-row:last-child {
    border-bottom: var(--border-width) solid var(--border);
  }

  .del-group-name {
    color: var(--accent);
    margin: 0;
  }

  .del-row-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .del-item {
    font-size: 11px;
    opacity: 0.65;
    position: relative;
    padding-left: 1rem;
  }

  .del-item::before {
    content: '—';
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.4;
  }

  /* ── PROCESS ── */
  .process-rows {
    display: flex;
    flex-direction: column;
  }

  .process-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 2rem;
    align-items: start;
    padding: 3rem 0;
    border-top: var(--border-width) solid var(--border);
    position: relative;
  }

  .process-row:last-child {
    border-bottom: var(--border-width) solid var(--border);
  }

  .process-num {
    font-family: var(--font-display);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(3.5rem, 6vw, 6rem);
    line-height: 1;
    letter-spacing: -0.03em;
    opacity: 0.08;
    color: var(--black-native);
    user-select: none;
  }

  .process-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .process-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--accent);
    margin: 0;
  }

  .process-desc {
    font-family: var(--font-body);
    font-size: var(--size-body);
    line-height: 1.65;
    opacity: 0.6;
    max-width: 55ch;
    margin: 0;
  }

  /* ── CTA ── */
  .svc-cta {
    min-height: 60vh;
  }

  .svc-cta-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: start;
    padding-top: clamp(4rem, 8vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 8rem);
  }

  .svc-cta-headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-on-dark);
    margin: 0 0 2rem;
  }

  .svc-cta-headline em {
    font-style: italic;
  }

  .svc-cta-sub {
    font-family: var(--font-body);
    font-size: var(--size-body);
    line-height: 1.7;
    color: var(--text-on-dark);
    opacity: 0.6;
    max-width: 45ch;
    margin: 0 0 2.5rem;
  }

  .svc-cta-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .svc-btn-ghost {
    opacity: 0.5;
  }

  .svc-cta-stats {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: var(--border-width) solid rgba(255,255,255,0.15);
  }

  .svc-stat {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 2rem 0;
    border-bottom: var(--border-width) solid rgba(255,255,255,0.12);
  }

  .svc-stat-val {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--accent);
  }

  .svc-stat-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-on-dark);
    opacity: 0.4;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .svc-hero-body {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .svc-cta-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .del-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .svc-manifesto-body {
      padding-left: 0;
    }
  }

  @media (max-width: 600px) {
    .svc-hero {
      min-height: 90vh;
    }

    .del-row-items {
      flex-direction: column;
      gap: 0.5rem;
    }

    .process-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .process-num {
      font-size: 3rem;
    }
  }
</style>

<script>
  import { animate, inView } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  // ── Hero entrance ──
  const heroTitle = document.querySelector<HTMLElement>('.svc-hero-title');
  if (heroTitle) {
    heroTitle.style.transform = 'translateY(60px)';
    heroTitle.style.opacity = '0';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroTitle, { transform: ['translateY(60px)', 'translateY(0px)'], opacity: [0, 1] }, { duration: 1.0, easing: ease, delay: 0.1 });
    }, 50);
  }

  const heroRight = document.querySelector<HTMLElement>('.svc-hero-right');
  if (heroRight) {
    heroRight.style.opacity = '0';
    heroRight.style.transform = 'translateY(24px)';
    setTimeout(() => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(heroRight, { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0px)'] }, { duration: 0.8, easing: ease, delay: 0.35 });
    }, 50);
  }

  // ── Line-wipe for [data-wipe] elements ──
  document.querySelectorAll<HTMLElement>('[data-wipe]').forEach(el => {
    el.style.transform = 'translateY(40px)';
    el.style.opacity = '0';
    inView(el, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(el, { transform: ['translateY(40px)', 'translateY(0px)'], opacity: [0, 1] }, { duration: 0.75, easing: ease });
    }, { amount: 0.2 });
  });

  // ── Fade for [data-fade] elements ──
  document.querySelectorAll<HTMLElement>('[data-fade]').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    inView(el, () => {
      // @ts-ignore — motion v12 overload resolution bug with HTMLElement
      animate(el, { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0px)'] }, { duration: 0.65, easing: ease, delay: i * 0.05 });
    }, { amount: 0.15 });
  });
</script>
