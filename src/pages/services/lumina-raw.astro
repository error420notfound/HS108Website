---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const deliverables = [
  { group: 'Photography', items: ['Product photography', 'Campaign & editorial photography', 'Brand lifestyle shoots', 'Photo retouching & colour grading', 'Social media image packages'] },
  { group: 'Videography', items: ['Brand films & documentaries', 'Product videos', 'Campaign & commercial shoots', 'Event & interview coverage', 'Drone & location footage'] },
  { group: 'Post-Production', items: ['Video editing & colour grade', 'Motion graphics & title design', 'Sound design & music licensing', 'Short-form cuts (Reels, TikTok)', 'Final export in all required formats'] },
];

const process = [
  { n: '01', title: 'Brief', desc: 'We align on story, tone, and visual language before anything goes in front of a lens.' },
  { n: '02', title: 'Pre-Production', desc: 'Shot lists, location scouting, talent & equipment planning — nothing improvised.' },
  { n: '03', title: 'Production', desc: 'The shoot. Controlled, efficient, and directed with a clear creative eye.' },
  { n: '04', title: 'Edit', desc: 'Post-production with full colour work, motion graphics, and formats for every platform.' },
];
---

<BaseLayout
  title="Lumina.raw"
  description="Lumina.raw is HS108's photo and video production practice — photography, videography, and post-production for brand storytelling."
  bodyClass="theme-green"
>
  <!-- Hero -->
  <div class="lr-hero inv-block">
    <div class="container lr-hero-inner">
      <div class="lr-hero-left">
        <span class="t-label lr-service-label">A Service by HS108</span>
        <p class="t-label lr-code">Lumina.raw</p>
        <h1 class="t-h1 lr-title">Photo<br />&amp; Video</h1>
        <div class="lr-tags">
          <span class="tag lr-tag">Photography</span>
          <span class="tag lr-tag">Videography</span>
          <span class="tag lr-tag">Motion</span>
        </div>
      </div>
      <div class="lr-hero-right">
        <p class="t-large lr-tagline">
          Visuals that stop the scroll. We produce photography and video content that tells your story with precision — edited and ready to publish.
        </p>
        <div class="lr-hero-meta">
          <div class="lr-meta-item">
            <span class="t-label lr-meta-label">Timeline</span>
            <span class="t-mono lr-meta-val">1–6 weeks depending on scope</span>
          </div>
          <div class="lr-meta-item">
            <span class="t-label lr-meta-label">Output</span>
            <span class="t-mono lr-meta-val">Fully edited, platform-ready files</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container lr-body">

    <!-- What we do -->
    <section class="lr-section">
      <div class="lr-two-col">
        <div>
          <p class="t-label" style="opacity:0.4; margin-bottom:1rem">What We Do</p>
          <h2 class="t-h2">Visuals that carry<br />the full story.</h2>
        </div>
        <div class="prose lr-prose">
          <p>
            Lumina.raw is the visual production arm of HS108. We shoot, direct, and edit photography and video content for brands that understand that how something looks is part of what it says.
          </p>
          <p>
            We work across product photography, campaign shoots, brand films, and ongoing content production. Every project starts with a brief that's as clear about emotion and narrative as it is about format and platform.
          </p>
          <p>
            The name reflects the approach: raw capture handled with precision and intention — not filtered presets and generic stock aesthetics.
          </p>
        </div>
      </div>
    </section>

    <hr />

    <!-- Deliverables -->
    <section class="lr-section">
      <p class="t-label" style="opacity:0.4; margin-bottom:3rem">Deliverables</p>
      <div class="del-grid">
        {deliverables.map(group => (
          <div class="del-group b-box">
            <p class="t-label del-group-title">{group.group}</p>
            <ul class="del-list">
              {group.items.map(item => (
                <li class="t-mono del-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- Process -->
    <section class="lr-section">
      <p class="t-label" style="opacity:0.4; margin-bottom:3rem">How We Work</p>
      <div class="process-grid">
        {process.map(step => (
          <div class="process-step b-box">
            <span class="t-label process-num">{step.n}</span>
            <h3 class="t-h3 process-title">{step.title}</h3>
            <p class="t-body process-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- CTA -->
    <section class="lr-section lr-cta">
      <div class="lr-cta-grid">
        <div>
          <h2 class="t-h2" style="margin-bottom:1rem">Start a Lumina.raw project.</h2>
          <p class="t-body" style="opacity:0.65; max-width:48ch; margin-bottom:2rem">
            Tell us what you need to capture — a product launch, a brand film, or an ongoing content system. We'll handle it end to end.
          </p>
          <div class="lr-cta-btns">
            <a href="/contact" class="btn btn--primary">Get In Touch</a>
            <a href="/services" class="btn btn--outline">← All Services</a>
          </div>
        </div>
        <div class="lr-stat-block inv-block">
          <p class="t-label" style="opacity:0.4; margin-bottom:2rem">Lumina.raw at a Glance</p>
          <div class="lr-stats">
            <div class="lr-stat">
              <span class="lr-stat-val t-h1">1–6</span>
              <span class="t-label lr-stat-label">Weeks typical engagement</span>
            </div>
            <div class="lr-stat">
              <span class="lr-stat-val t-h1">All</span>
              <span class="t-label lr-stat-label">Formats delivered — social to broadcast</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <ContactCTA
    headline="Need the full picture?"
    sub="Lumina.raw pairs with CX&Identity and WebCanvas for launch-ready brand assets across every medium."
  />
</BaseLayout>

<style>
  .lr-hero {
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    padding-top: 10rem;
    padding-bottom: 0;
  }

  .lr-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
    padding-bottom: 4rem;
    border-bottom: var(--border-width) solid rgba(255,255,255,0.15);
  }

  .lr-service-label {
    opacity: 0.4;
    display: block;
    margin-bottom: 1.5rem;
    color: var(--text-on-dark);
  }

  .lr-code {
    color: var(--accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .lr-title {
    color: var(--text-on-dark);
    margin-bottom: 1.5rem;
  }

  .lr-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .lr-tag {
    border-color: rgba(255,255,255,0.2);
    color: var(--text-on-dark);
  }

  .lr-tagline {
    color: var(--text-on-dark);
    opacity: 0.7;
    max-width: 50ch;
    margin-bottom: 2rem;
  }

  .lr-hero-meta {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .lr-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .lr-meta-label {
    opacity: 0.35;
    color: var(--text-on-dark);
  }

  .lr-meta-val {
    color: var(--text-on-dark);
    font-size: 12px;
  }

  .lr-body {
    padding-bottom: var(--space-section);
  }

  .lr-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .lr-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .lr-prose p {
    margin-bottom: 1.25rem;
    opacity: 0.7;
    line-height: 1.75;
    max-width: 60ch;
  }

  .del-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-gap);
  }

  .del-group {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .del-group-title {
    color: var(--accent);
  }

  .del-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .del-item {
    padding-left: 1rem;
    position: relative;
    opacity: 0.65;
    font-size: 11px;
  }

  .del-item::before {
    content: '→';
    position: absolute;
    left: 0;
    font-size: 10px;
    opacity: 0.5;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-gap);
  }

  .process-step {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .process-num { opacity: 0.3; }

  .process-title { color: var(--accent); }

  .process-desc {
    opacity: 0.6;
    font-size: 14px;
    line-height: 1.6;
  }

  .lr-cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .lr-cta-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .lr-stat-block {
    padding: var(--space-card);
  }

  .lr-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .lr-stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .lr-stat-val {
    color: var(--accent);
    line-height: 1;
  }

  .lr-stat-label {
    opacity: 0.4;
    color: var(--text-on-dark);
  }

  @media (max-width: 900px) {
    .lr-hero-inner,
    .lr-two-col,
    .lr-cta-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .del-grid {
      grid-template-columns: 1fr;
    }

    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { animate, inView, stagger } from 'motion';
  const ease = [0.16, 1, 0.3, 1] as const;

  const hero = document.querySelector<HTMLElement>('.lr-hero-inner');
  if (hero) {
    hero.style.opacity = '0';
    animate(hero, { opacity: [0, 1], transform: ['translateY(24px)', 'translateY(0px)'] }, { duration: 0.65, easing: ease });
  }

  document.querySelectorAll<HTMLElement>('.del-group').forEach(group => {
    group.style.opacity = '0';
    inView(group, () => {
      animate(group, { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0px)'] }, { duration: 0.55, easing: ease });
    }, { amount: 0.1 });
  });

  const processGrid = document.querySelector<HTMLElement>('.process-grid');
  if (processGrid) {
    const steps = processGrid.querySelectorAll<HTMLElement>('.process-step');
    steps.forEach(el => { el.style.opacity = '0'; });
    inView(processGrid, () => {
      animate(steps, { opacity: [0, 1], transform: ['translateY(20px)', 'translateY(0px)'] }, { duration: 0.5, easing: ease, delay: stagger(0.08) });
    }, { amount: 0.1 });
  }
</script>
