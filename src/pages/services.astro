---
import PageLayout from '@layouts/PageLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const services = [
  {
    num: '01',
    code: 'WebCanvas',
    name: 'Digital Design',
    desc: 'End-to-end digital experiences — from the first wireframe to the final pixel. We design websites, apps, and product interfaces that are intuitive, accessible, and built to perform.',
    deliverables: ['Web design (marketing, product, landing pages)', 'App UI design (iOS & Android)', 'UX research & user journey mapping', 'Wireframes & interactive prototypes', 'Responsive design across all breakpoints', 'Developer handoff (Figma)'],
    timeline: '4–16 weeks',
    accent: 'Web · App · UI · UX',
  },
  {
    num: '02',
    code: 'CX&Identity',
    name: 'Branding & Identity',
    desc: 'A brand is more than a logo. We build the full identity system — strategy, visual language, and the guidelines that keep it coherent as your company grows.',
    deliverables: ['Brand strategy & positioning', 'Logo system & wordmark', 'Type, colour & imagery system', 'Packaging design', 'Brand guidelines document', 'Launch assets & stationery'],
    timeline: '6–10 weeks',
    accent: 'Logo · Identity · Packaging',
  },
  {
    num: '03',
    code: 'CMF_Nexus',
    name: 'Product Design',
    desc: 'From concept sketch to production-ready file. We blend design thinking with engineering rigour to develop products that look right, work right, and manufacture efficiently.',
    deliverables: ['Concept sketches & ideation', 'CAD modelling & 3D design', 'CMF (colour, material, finish) specification', 'Prototyping & model making', 'Production-ready design files', 'Manufacture liaison support'],
    timeline: '8–20 weeks',
    accent: 'CAD · Prototype · Production',
  },
  {
    num: '04',
    code: 'Lumina.raw',
    name: 'Photo & Video',
    desc: 'Visuals that stop the scroll. We produce photography and video content that tells your story with precision — from product shoots to brand films, edited and ready to publish.',
    deliverables: ['Product & campaign photography', 'Photo editing & retouching', 'Brand & documentary videography', 'Video editing & post-production', 'Social media content packages', 'Motion graphics'],
    timeline: '1–6 weeks',
    accent: 'Photo · Video · Motion',
  },
];
---

<PageLayout title="Services" label="What We Do" description="HS108 design services — WebCanvas, CX&Identity, CMF_Nexus, and Lumina.raw. Digital design, branding, product design, and visual production.">

  <div class="container services-intro">
    <p class="t-large services-lede">
      Four specialised practices. One studio.
      We don't offer everything — we offer the things we're exceptional at.
    </p>
  </div>

  <div class="services-list">
    {services.map(svc => (
      <div class="svc-row container">
        <div class="svc-header">
          <span class="t-label svc-num">{svc.num}</span>
          <div class="svc-name-block">
            <span class="t-label svc-code">{svc.code}</span>
            <h2 class="t-h2 svc-name">{svc.name}</h2>
          </div>
          <span class="tag svc-accent">{svc.accent}</span>
          <span class="tag">{svc.timeline}</span>
        </div>
        <div class="svc-body">
          <p class="t-body svc-desc">{svc.desc}</p>
          <div class="svc-deliverables">
            <p class="t-label svc-del-label">Deliverables</p>
            <ul class="svc-del-list">
              {svc.deliverables.map(d => <li class="t-mono">{d}</li>)}
            </ul>
          </div>
        </div>
        <hr />
      </div>
    ))}
  </div>

  <!-- Programs callout -->
  <div class="container services-programs">
    <p class="t-label" style="opacity:0.4; margin-bottom:1.5rem">Also From HS108</p>
    <div class="programs-grid">
      <div class="program-card b-box">
        <p class="t-label program-label">Creative Department</p>
        <p class="t-body program-desc">Our flagship retainer — an embedded design team that grows with your business.</p>
        <a href="/programs/creative-department" class="btn btn--outline">Learn More →</a>
      </div>
      <div class="program-card b-box">
        <p class="t-label program-label">Design Lab</p>
        <p class="t-body program-desc">Research and discovery for high-demand, complex design challenges.</p>
        <a href="/programs/design-lab" class="btn btn--outline">Learn More →</a>
      </div>
      <div class="program-card b-box">
        <p class="t-label program-label">off_menu</p>
        <p class="t-body program-desc">Bespoke, tailor-made packages for clients with unique requirements.</p>
        <a href="/programs/off-menu" class="btn btn--outline">Learn More →</a>
      </div>
      <div class="program-card b-box">
        <p class="t-label program-label">Atelier Discourse</p>
        <p class="t-body program-desc">A platform for discourse with designers, artisans, and industry thinkers.</p>
        <a href="/programs/atelier-discourse" class="btn btn--outline">Learn More →</a>
      </div>
    </div>
  </div>

  <!-- Callout -->
  <div class="container services-callout inv-block">
    <p class="t-label" style="opacity:0.4; margin-bottom:1rem">Not sure what you need?</p>
    <h2 class="t-h2" style="margin-bottom:1.5rem">Start with a conversation.</h2>
    <p class="t-body" style="opacity:0.6; max-width:50ch; margin-bottom:2rem">
      Most projects don't fit neatly into one service. Tell us what you're building
      and we'll figure out the right scope together.
    </p>
    <a href="/contact" class="btn btn--outline-inv">Get In Touch</a>
  </div>

  <ContactCTA invert={false} />

</PageLayout>

<style>
  .services-intro {
    padding-top: 3rem;
    padding-bottom: 3rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .services-lede {
    max-width: 65ch;
  }

  .services-list {
    display: flex;
    flex-direction: column;
  }

  .svc-row {
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .svc-header {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .svc-num {
    opacity: 0.3;
    flex-shrink: 0;
  }

  .svc-name-block {
    flex: 1;
  }

  .svc-code {
    opacity: 0.45;
    display: block;
    margin-bottom: 0.35rem;
    color: var(--accent);
  }

  .svc-name {
    line-height: 1;
  }

  .svc-accent {
    background: var(--surface-elevated);
    opacity: 0.7;
  }

  .svc-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  .svc-desc {
    opacity: 0.65;
    max-width: 55ch;
    line-height: 1.7;
  }

  .svc-del-label {
    opacity: 0.4;
    margin-bottom: 1rem;
  }

  .svc-del-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .svc-del-list li {
    padding-left: 1.25rem;
    position: relative;
    opacity: 0.7;
  }

  .svc-del-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    opacity: 0.4;
    font-family: var(--font-mono);
    font-size: 10px;
  }

  /* Programs grid */
  .services-programs {
    padding-top: var(--space-section);
    padding-bottom: var(--space-section);
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-gap);
    margin-top: 1.5rem;
  }

  .program-card {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .program-label {
    color: var(--accent);
  }

  .program-desc {
    opacity: 0.6;
    line-height: 1.6;
    flex: 1;
    font-size: 14px;
  }

  /* Callout */
  .services-callout {
    padding: var(--space-section) var(--gutter);
    margin-top: 0;
  }

  @media (max-width: 900px) {
    .svc-body {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .programs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .programs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
