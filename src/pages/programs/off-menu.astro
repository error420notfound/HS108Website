---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const examples = [
  {
    code: 'OM-001',
    title: 'Full-Studio Brand Launch',
    desc: 'A client needed naming, identity, packaging, web design, and launch photography — all from one team, under one vision. off_menu made it possible.',
    scope: 'CX&Identity + WebCanvas + Lumina.raw',
  },
  {
    code: 'OM-002',
    title: 'Product + Digital Ecosystem',
    desc: 'Hardware product design combined with a companion app and brand identity for a single cohesive launch. Cross-discipline, custom-scoped.',
    scope: 'CMF_Nexus + WebCanvas + CX&Identity',
  },
  {
    code: 'OM-003',
    title: 'Brand Overhaul + Content Engine',
    desc: 'A rebrand paired with an ongoing visual content system — photography and video produced monthly to maintain the new identity across channels.',
    scope: 'CX&Identity + Lumina.raw (retainer)',
  },
  {
    code: 'OM-004',
    title: 'Discovery + Design Sprint',
    desc: 'For a client who didn\'t know what they needed — a structured discovery engagement that delivered clarity, direction, and a design plan of action.',
    scope: 'Strategy + Design Lab',
  },
];

const process = [
  { n: '01', title: 'Tell Us', desc: 'Describe your situation, your goal, and whatever constraints you\'re working with. Nothing is too unusual.' },
  { n: '02', title: 'We Scope', desc: 'We figure out the right mix of practices, people, and timeline. You get a clear proposal — no surprises.' },
  { n: '03', title: 'We Build', desc: 'The work happens across whatever disciplines your project needs, coordinated internally by us.' },
  { n: '04', title: 'You Launch', desc: 'Delivery is designed around your timeline. We stay through handoff and can continue as a retainer if needed.' },
];
---

<BaseLayout
  title="off_menu"
  description="off_menu is HS108's bespoke program — custom, tailor-made packages that address unique client requirements across disciplines."
  bodyClass="theme-cool"
>
  <!-- Header -->
  <div class="om-hero">
    <div class="container om-hero-inner">
      <div class="om-overline">
        <span class="t-label" style="opacity:0.4">Program by HS108</span>
        <span class="t-label om-sep">×</span>
        <span class="t-label om-badge tag tag--accent">Bespoke</span>
      </div>

      <h1 class="t-hero om-title">off_menu</h1>

      <div class="om-rule"></div>

      <p class="t-large om-tagline">
        Your project doesn't fit a standard package.<br />
        That's exactly why off_menu exists.<br />
        Custom scope. Tailored team. One seamless engagement.
      </p>
    </div>
  </div>

  <div class="container om-body">

    <!-- What it is -->
    <section class="om-section">
      <div class="om-what-grid">
        <div>
          <p class="t-label section-num" style="opacity:0.4; margin-bottom:1rem">What Is off_menu?</p>
          <h2 class="t-h2">Design built around you.</h2>
        </div>
        <div class="prose om-prose">
          <p>
            Most design studios have fixed packages. You choose one, they deliver it. Simple — unless your needs don't fit the menu.
          </p>
          <p>
            off_menu is for clients who need something different. A cross-discipline project that spans branding, product design, and visual content. A brief that sits between categories. An engagement structure that doesn't match any retainer or one-off model.
          </p>
          <p>
            We take your actual situation — the scope, the team you need, the timeline you're working with — and build a bespoke engagement around it. All four HS108 practices are available to combine as the work demands.
          </p>
          <p>
            If standard packages feel like a compromise, off_menu is the alternative.
          </p>
        </div>
      </div>
    </section>

    <hr />

    <!-- Example project types -->
    <section class="om-section">
      <p class="t-label section-num" style="opacity:0.4; margin-bottom:3rem">Example Engagements</p>

      <div class="om-grid">
        {examples.map(proj => (
          <div class="om-card b-box">
            <div class="om-card-header">
              <span class="t-label om-code">{proj.code}</span>
            </div>
            <h3 class="t-h3 om-card-title">{proj.title}</h3>
            <p class="t-body om-card-desc">{proj.desc}</p>
            <span class="tag om-scope">{proj.scope}</span>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- How it works -->
    <section class="om-section">
      <p class="t-label" style="opacity:0.4; margin-bottom:3rem">How It Works</p>

      <div class="om-process">
        {process.map(step => (
          <div class="om-step b-box">
            <span class="t-label om-step-num">{step.n}</span>
            <h3 class="t-h3 om-step-title">{step.title}</h3>
            <p class="t-body om-step-desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- CTA -->
    <section class="om-section om-cta-section">
      <div class="om-cta-grid">
        <div>
          <h2 class="t-h2" style="margin-bottom:1rem">Have something unusual in mind?</h2>
          <p class="t-body" style="opacity:0.6; max-width:45ch; margin-bottom:2rem">
            Tell us what you're trying to do — even if you're not sure how to frame it. That's where off_menu starts.
          </p>
          <div class="om-ctas">
            <a href="/contact" class="btn btn--primary">Start a Conversation</a>
            <a href="mailto:contact.studio@hs108.in" class="btn btn--outline">contact.studio@hs108.in</a>
          </div>
        </div>

        <div class="om-criteria-box inv-block">
          <p class="t-label" style="opacity:0.4; margin-bottom:1.5rem">off_menu is right for you if…</p>
          <ul class="om-criteria">
            {[
              'Your project spans more than one design discipline',
              'You need a single team across the full scope',
              'Standard packages don\'t reflect your actual needs',
              'You want one point of contact, not multiple agencies',
              'You\'re building something that doesn\'t have a precedent',
            ].map(c => <li class="t-mono">{c}</li>)}
          </ul>
        </div>
      </div>
    </section>

  </div>

  <ContactCTA
    headline="Looking for something more standard?"
    sub="off_menu is for complex, bespoke projects. Our four core services handle more focused engagements."
  />
</BaseLayout>

<style>
  /* Hero */
  .om-hero {
    margin-top: 64px;
    padding-top: 4rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .om-hero-inner {
    padding-bottom: 3rem;
  }

  .om-overline {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .om-sep {
    opacity: 0.2;
  }

  .om-title {
    font-size: var(--size-hero);
    font-family: var(--font-mono);
    font-weight: 500;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    line-height: 0.85;
  }

  .om-rule {
    height: var(--border-width);
    background: var(--black-native);
    margin-bottom: 2rem;
  }

  .om-tagline {
    max-width: 55ch;
    opacity: 0.7;
    line-height: 1.55;
  }

  /* Body */
  .om-body {
    padding-bottom: var(--space-section);
  }

  .om-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .om-what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .om-prose p {
    margin-bottom: 1.25rem;
    opacity: 0.7;
    line-height: 1.75;
    max-width: 60ch;
  }

  /* Cards */
  .om-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-gap);
  }

  .om-card {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .om-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .om-code {
    opacity: 0.3;
  }

  .om-card-title {
    line-height: 1.2;
  }

  .om-card-desc {
    opacity: 0.6;
    line-height: 1.65;
    flex: 1;
  }

  .om-scope {
    align-self: flex-start;
    color: var(--accent);
    background: var(--surface-elevated);
    opacity: 0.85;
  }

  /* Process */
  .om-process {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-gap);
  }

  .om-step {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .om-step-num {
    opacity: 0.3;
  }

  .om-step-title {
    color: var(--accent);
  }

  .om-step-desc {
    opacity: 0.6;
    line-height: 1.6;
    font-size: 14px;
  }

  /* CTA */
  .om-cta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .om-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .om-criteria-box {
    padding: var(--space-card);
  }

  .om-criteria {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .om-criteria li {
    padding-left: 1.5rem;
    position: relative;
    opacity: 0.65;
    color: var(--text-on-dark);
    font-size: 11px;
  }

  .om-criteria li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 10px;
  }

  @media (max-width: 900px) {
    .om-what-grid,
    .om-cta-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .om-grid,
    .om-process {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .om-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
