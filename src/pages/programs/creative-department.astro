---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactCTA from '@components/ContactCTA.astro';

const included = [
  { label: 'Dedicated Design Team', desc: 'Senior designers allocated to your account — no juniors, no generalists.' },
  { label: 'Monthly Design Sprints', desc: 'Structured cycles of briefing, design, and review. Predictable, fast, repeatable.' },
  { label: 'All Four Practices', desc: 'Access to WebCanvas, CX&Identity, CMF_Nexus, and Lumina.raw under one retainer.' },
  { label: 'Async Collaboration', desc: 'No time zone friction. We work in your tools, on your schedule.' },
  { label: 'Quarterly Strategy Reviews', desc: 'We step back from the work every quarter to align on direction, priorities, and goals.' },
  { label: 'Unlimited Requests', desc: 'Raise design needs as they come. No scope debates, no change orders for small asks.' },
];

const suits = [
  'Companies with ongoing, evolving design needs',
  'Brands that want embedded design — not freelancers',
  'Teams that have shipped product and need design to keep pace with growth',
  'Businesses replacing or augmenting an internal design function',
];
---

<BaseLayout
  title="Creative Department"
  description="Creative Department is HS108's flagship retainer program — a dedicated design team embedded in your business for ongoing support, consistency, and growth."
>
  <!-- Header — inverted -->
  <div class="cd-hero inv-block">
    <div class="container cd-hero-inner">
      <div class="cd-logo">
        <span class="t-label" style="opacity:0.4">Program by HS108</span>
        <h1 class="t-h1 cd-title">Creative<br />Department</h1>
        <span class="tag tag--inv cd-tag">Retainer</span>
      </div>

      <p class="t-large cd-tagline">
        Your design team, without the overhead of hiring one.
        A dedicated allocation of senior design talent, embedded in your business
        and available as your needs evolve.
      </p>
    </div>
  </div>

  <div class="container cd-body">

    <!-- What it is -->
    <section class="cd-section">
      <div class="cd-section-grid">
        <div class="cd-section-left">
          <p class="t-label section-num" style="opacity:0.4">What It Is</p>
        </div>
        <div class="cd-section-right">
          <div class="prose">
            <p>
              Creative Department is HS108's flagship retainer program. It gives businesses consistent, high-quality design support without the cost and complexity of building an in-house team.
            </p>
            <p>
              Instead of briefing a studio project-by-project — waiting for quotes, negotiating scope, onboarding teams repeatedly — Creative Department clients get a dedicated design function that knows their brand, their product, and their goals.
            </p>
            <p>
              It's the model that makes sense when design is not a one-off need but an ongoing engine of your business.
            </p>
          </div>
        </div>
      </div>
    </section>

    <hr />

    <!-- What's included -->
    <section class="cd-section">
      <p class="t-label" style="opacity:0.4; margin-bottom:3rem">What's Included</p>

      <div class="included-grid">
        {included.map(item => (
          <div class="included-row b-box">
            <p class="t-label included-label">{item.label}</p>
            <p class="t-body included-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <!-- Who it suits -->
    <section class="cd-section">
      <div class="cd-section-grid">
        <div class="cd-section-left">
          <p class="t-label" style="opacity:0.4">Who It's For</p>
        </div>
        <div class="cd-section-right">
          <ul class="suits-list">
            {suits.map(s => (
              <li class="suits-item t-body">
                <span class="suits-tick">→</span>
                {s}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <hr />

    <!-- Start -->
    <section class="cd-section cd-start">
      <div class="cd-start-grid">
        <div>
          <h2 class="t-h2" style="margin-bottom:1rem">Ready to talk?</h2>
          <p class="t-body" style="opacity:0.65; max-width:48ch; margin-bottom:2rem">
            Creative Department engagements are scoped to each client. Tell us where you are and what you need — we'll put together the right structure.
          </p>
          <div class="cd-ctas">
            <a href="/contact" class="btn btn--primary">Start a Conversation</a>
            <a href="mailto:contact.studio@hs108.in" class="btn btn--outline">contact.studio@hs108.in</a>
          </div>
        </div>
        <div class="cd-stat-box inv-block">
          <p class="t-label" style="opacity:0.4; margin-bottom:2rem">The Creative Department Difference</p>
          <div class="cd-stats">
            <div class="cd-stat">
              <span class="t-hero cd-stat-val">100%</span>
              <span class="t-label cd-stat-label">Senior talent</span>
            </div>
            <div class="cd-stat">
              <span class="t-hero cd-stat-val">4</span>
              <span class="t-label cd-stat-label">Practices under one retainer</span>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div>

  <ContactCTA
    headline="Interested in our project-based services?"
    sub="Creative Department is our retainer model. For one-time projects, explore our full service offering."
  />
</BaseLayout>

<style>
  .cd-hero {
    min-height: 55vh;
    display: flex;
    align-items: flex-end;
    padding-top: 10rem;
    padding-bottom: 0;
  }

  .cd-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
    padding-bottom: 4rem;
    border-bottom: var(--border-width) solid rgba(255,255,255,0.15);
  }

  .cd-title {
    margin-top: 1rem;
    color: var(--text-on-dark);
  }

  .cd-tag {
    margin-top: 1.5rem;
    display: inline-block;
  }

  .tag--inv {
    border-color: rgba(255,255,255,0.2);
    color: var(--text-on-dark);
  }

  .cd-tagline {
    opacity: 0.65;
    color: var(--text-on-dark);
    max-width: 50ch;
    align-self: end;
  }

  /* Body */
  .cd-body {
    padding-bottom: var(--space-section);
  }

  .cd-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .cd-section-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
  }

  .cd-section-right .prose p {
    margin-bottom: 1.25rem;
    opacity: 0.7;
    line-height: 1.75;
    max-width: 65ch;
  }

  /* Included */
  .included-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-gap);
  }

  .included-row {
    padding: var(--space-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .included-label {
    color: var(--accent);
  }

  .included-desc {
    opacity: 0.6;
    line-height: 1.6;
    font-size: 14px;
  }

  /* Who it suits */
  .suits-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60ch;
  }

  .suits-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    opacity: 0.7;
    line-height: 1.6;
  }

  .suits-tick {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    padding-top: 4px;
    flex-shrink: 0;
  }

  /* Start */
  .cd-start-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .cd-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .cd-stat-box {
    padding: var(--space-card);
  }

  .cd-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .cd-stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .cd-stat-val {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    color: var(--accent);
  }

  .cd-stat-label {
    opacity: 0.45;
    color: var(--text-on-dark);
  }

  @media (max-width: 900px) {
    .cd-hero-inner,
    .cd-section-grid,
    .cd-start-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .included-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
